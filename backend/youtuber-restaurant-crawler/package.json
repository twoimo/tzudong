{
  "name": "youtube-restaurant-crawler",
  "version": "1.0.0",
  "description": "유튜버 맛집 크롤러 - 정육왕 채널 등의 맛집 데이터 수집",
  "type": "module",
  "main": "scripts/main.js",
  "scripts": {
    "crawl": "bun run scripts/crawl-channel.js",
    "extract": "bun run scripts/extract-addresses.js",
    "geocode": "bun run scripts/enrich-coordinates.js",
    "insert": "bun run scripts/insert-to-supabase.js",
    "pipeline": "bun run scripts/pipeline.js",
    "full": "bun run oauth && bun run crawl && bun run extract && bun run geocode && bun run insert",
    "oauth": "bun run scripts/gemini-oauth-manager.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "puppeteer": "^22.0.0"
  },
  "trustedDependencies": [
    "puppeteer"
  ]
}