{
  "name": "geminiCLI-restaurant-evaluation",
  "version": "1.0.0",
  "description": "Gemini CLI based restaurant evaluation pipeline",
  "main": "scripts/insert_to_supabase.ts",
  "type": "module",
  "scripts": {
    "pipeline": "python3 scripts/evaluation-pipeline.py",
    "evaluate": "bash scripts/evaluation.sh",
    "retry": "bash scripts/retry_errors.sh",
    "transform": "python3 scripts/transform_evaluation_results.py",
    "insert": "tsx scripts/insert_to_supabase.ts",
    "target-selection": "python3 scripts/evaluation-target-selection.py",
    "rule-eval": "python3 scripts/evaluation-rule.py",
    "full-pipeline": "python3 ../geminiCLI-restaurant-pipeline.py"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
