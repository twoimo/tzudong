9,"text":"딱 먹으면 부드러운 아구 살이랑 쫄깃쫄깃한 아구 위가 있어서"},{"start":709.102,"duration":1.5480000000000018,"text":"맛이 없을 수가 없어요...!"},{"start":722.15,"duration":1.8500000000000227,"text":"보통 약간 방송에 나온다고"},{"start":724.002,"duration":2.2480000000000473,"text":"잠깐 반짝하는 맛집은 많아도"},{"start":726.252,"duration":1.4480000000000928,"text":"꾸준히 그러는 건 힘들잖아요"},{"start":727.702,"duration":2.947999999999979,"text":"근데 여기는 정말 촬영 후에도"},{"start":730.651,"duration":3.799000000000092,"text":"계속 손님들이 꾸준히 오셔서 이렇게 커졌다고 하더라고요"},{"start":734.452,"duration":5.048000000000002,"text":"정말 다들 애정하는 맛집이라는 리뷰들이 많아서"},{"start":739.502,"duration":2.09800000000007,"text":"굉장히 기대를 하면서 왔는데"},{"start":741.602,"duration":1.197999999999979,"text":"진짜 맛은 오히려"},{"start":742.801,"duration":1.8489999999999327,"text":"제가 기대했던 것보다 이상인 것 같아요!"},{"start":750.1,"duration":0.9499999999999318,"text":"진짜 맛있다"},{"start":770.202,"duration":1.197999999999979,"text":"감사합니다"},{"start":776.2,"duration":4.599999999999909,"text":"익숙하다 했더니 사장님이었구나"},{"start":780.802,"duration":1.3980000000000246,"text":"마지막 아구순살튀김"},{"start":788.35,"duration":1.8999999999999773,"text":"아구가 자주 먹는 음식은 아니잖아요"},{"start":790.252,"duration":3.2480000000000473,"text":"아무래도 아구 자체가 비싸기도 하고"},{"start":793.502,"duration":1.3980000000000246,"text":"아구덮밥을 1만 원에 먹을 수 있으면"},{"start":794.901,"duration":1.3490000000000464,"text":"저는 너무 좋은 것 같아요!"},{"start":796.252,"duration":1.7980000000000018,"text":"진짜 이 양념도 맛있고..."},{"start":803.6,"duration":3,"text":"아구를 살짝 볶아서 만든 것 같은데"},{"start":807.25,"duration":1.0499999999999545,"text":"맛있겠다"},{"start":825.4,"duration":1.8999999999999773,"text":"가쓰오부시 맛이 약간 진짜"},{"start":827.301,"duration":2.5989999999999327,"text":"살짝 일식 볶음우동 같기도 해요!"},{"start":829.901,"duration":3.299000000000092,"text":"볶음우동인데 간장 베이스 말고"},{"start":833.202,"duration":2.7480000000000473,"text":"매콤 베이스로 만든 볶음우동 맛도 나요"},{"start":846.45,"duration":2.0499999999999545,"text":"둘 중에 뭐가 더 맛있다고 할 수 없는 게"},{"start":848.502,"duration":1.5480000000000018,"text":"너무 다른 매력이다"}