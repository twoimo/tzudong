{"youtube_link":"https://www.youtube.com/watch?v=UyKDyky_Sho","channel_name":"tzuyang","language":"ko","collected_at":"2026-02-12T16:26:10.941+09:00","transcript":[{"start":0.002,"duration":1.148,"text":"중식인데"},{"start":1.152,"duration":4.098,"text":"짜장면에 오징어볶음이 같이 나오더라고요"},{"start":13.8,"duration":1.5,"text":"이거는 맛없없..."},{"start":15.302,"duration":1.9480000000000004,"text":"맛이 없을 수 없는 조합이에요"},{"start":19.552,"duration":3.097999999999999,"text":"짬뽕이 얼마나 맛있길래 이걸 놔두고 드시는 거지?"},{"start":43.402,"duration":1.8979999999999961,"text":"안녕하세요, 여러분"},{"start":45.302,"duration":2.597999999999999,"text":"제가 오늘은 지급 삽교에 왔는데"},{"start":47.902,"duration":2.1980000000000004,"text":"여기가 이제... 서해!"},{"start":50.102,"duration":4.248000000000005,"text":"삽교 중에서도 바다 근처에 있는 삽교호거든요"},{"start":54.352,"duration":2.4480000000000004,"text":"제가 되게 먹어보고 싶은 곳이 있어서 찾아왔어요"},{"start":56.802,"duration":1.7479999999999976,"text":"중식인데"},{"start":58.552,"duration":3.9979999999999976,"text":"짜장면에 오징어볶음이 같이 나오더라고요"},{"start":62.552,"duration":2.7979999999999947,"text":"예전에 짬짜면이라고 반반..."},{"start":65.351,"duration":1.9989999999999952,"text":"이렇게 진짜 비벼서 먹는 걸 먹은 적 있는데"},{"start":67.351,"duration":0.7489999999999952,"text":"약간 그런 것처럼"},{"start":68.101,"duration":2.8490000000000038,"text":"오징어볶음이랑 짜장면을 비벼 먹는"},{"start":70.952,"duration":3.298000000000002,"text":"그런 좀 특이한 오징어볶음짜장면?"},{"start":74.252,"duration":1.2980000000000018,"text":"오볶짜장?"},{"start":75.551,"duration":2.0990000000000038,"text":"아무튼 특이한 짜장면이 있어서 찾아왔어요"},{"start":77.652,"duration":2.397999999999996,"text":"오늘 여기서 짜장면 먹고"},{"start":80.051,"duration":2.3490000000000038,"text":"저녁에는 조개구이 먹을 거예요"},{"start":82.402,"duration":1.8979999999999961,"text":"조개구이 너무 오랜만에... 당긴다"},{"start":84.301,"duration":1.399000000000001,"text":"겨울에만 딱 먹을 수 있으니까"},{"start":85.702,"duration":1.5480000000000018,"text":"지금 영하 체감..."},{"start":87.252,"duration":2.1980000000000075,"text":"-20℃ 가까이 되거든요?"},{"start":89.452,"duration":2.4480000000000075,"text":"엄청 추운데... 빨리 들어가 보겠습니다"},{"start":93.452,"duration":3.548000000000002,"text":"사실 여기 제가 지금 세 번째 섭외 요청을 했거든요"},{"start":97.00200000000001,"duration":2.7479999999999905,"text":"문이 계속 닫혀있어서"},{"start":99.75200000000001,"duration":2.0479999999999876,"text":"한 번은 왔는데 못 먹고"},{"start":101.801,"duration":1.698999999999998,"text":"한 번은 전화했는데 휴일이었고"},{"start":103.50200000000001,"duration":1.6479999999999961,"text":"그래서 계속 못 먹다가"},{"start":105.152,"duration":2.897999999999996,"text":"오늘 드디어 왔어요! 드디어 열려있어서"},{"start":110.452,"duration":1.597999999999999,"text":"안녕하세요"},{"start":112.051,"duration":3.649000000000001,"text":"지금 메뉴판에... 오징어볶음 짜장면이 없는데...?"},{"start":118.551,"duration":2.3490000000000038,"text":"반갑습니다, 안녕하세요"},{"start":120.902,"duration":2.4479999999999933,"text":"저희 계속 찾아왔는데..."},{"start":126.851,"duration":1.6990000000000123,"text":"계속 와보고 싶었거든요"},{"start":128.552,"duration":2.598000000000013,"text":"- 지금 올해 10년 정도 했어요 - 10년 정도...!"},{"start":131.152,"duration":1.3980000000000246,"text":"와... 되게 오래 하셨구나~"},{"start":132.552,"duration":2.498000000000019,"text":"- 간판이 바닷바람 때문에 지워진 거예요? - 네-!"},{"start":135.052,"duration":2.598000000000013,"text":"저희 신랑이 노포 느낌 난다고"},{"start":137.652,"duration":1.7980000000000018,"text":"간판을 처리 안 하고"},{"start":139.452,"duration":3.598000000000013,"text":"계속 놔두고 있는 중이에요ㅎㅎ"},{"start":143.052,"duration":2.6980000000000075,"text":"그... 여기 오징어볶음 짜장면이 있다고 들었는데"},{"start":145.752,"duration":2.697999999999979,"text":"- 메뉴판에 없어서요 - 그게 쟁반짜장이에요-!"},{"start":148.452,"duration":3.2479999999999905,"text":"아 쟁반짜장!"},{"start":151.702,"duration":2.298000000000002,"text":"아 저는 없어졌나 해서 놀랐어요"},{"start":154.55,"duration":1.8499999999999943,"text":"그냥 탕수육하고 복분자탕수육하고 달라요?"},{"start":156.402,"duration":1.3480000000000132,"text":"복분자 열매가 들어가요"},{"start":157.752,"duration":1.697999999999979,"text":"- 진짜 실제로요? - 네"},{"start":159.452,"duration":1.5980000000000132,"text":"그건 아마..."},{"start":161.052,"duration":3.647999999999996,"text":"- 다른 곳에도 없을 거예요... - 그러니까요"},{"start":164.702,"duration":2.348000000000013,"text":"원래 주말에 웨이팅이 좀 있고"},{"start":167.052,"duration":1.8979999999999961,"text":"기다리시는 손님도 계시고 해서"},{"start":168.952,"duration":1.5480000000000018,"text":"추가 주문이 어려운데"},{"start":170.502,"duration":2.2479999999999905,"text":"원래 이렇게 한가한 시간에는 해주신다고 하셔서"},{"start":172.752,"duration":1.5979999999999848,"text":"하나씩 시켜 먹어보도록 하겠습니다"},{"start":174.352,"duration":4.548000000000002,"text":"일단 탕수육 하나랑요"},{"start":178.902,"duration":2.6480000000000246,"text":"그리고 만두, 쟁반짜장"},{"start":181.552,"duration":1.2980000000000018,"text":"일단은 이렇게만 주세요"},{"start":236.202,"duration":1.3480000000000132,"text":"양 엄청 많다"},{"start":237.552,"duration":2.248000000000019,"text":"양이 와...."},{"start":239.802,"duration":1.7980000000000018,"text":"오징어랑 면 섞어서 드시면 돼요-!"},{"start":241.602,"duration":0.7980000000000018,"text":"- 섞어서요? - 네"},{"start":242.402,"duration":1.8480000000000132,"text":"- 다 같이 처음부터 섞어서요? - 네"},{"start":244.252,"duration":2.2479999999999905,"text":"- 먹다가 섞기도 하는 거죠? - 네네, 맞아요"},{"start":246.502,"duration":1.447999999999979,"text":"알겠습니다, 감사합니다"},{"start":247.952,"duration":2.897999999999996,"text":"일단 조금 이따가 그냥 짜장면 먹을 거기 때문에"},{"start":250.852,"duration":1.5480000000000018,"text":"이거는 바로 섞어서 먹을게요"},{"start":260.6,"duration":1.349999999999966,"text":"진짜 궁금했거든요"},{"start":261.952,"duration":2.8980000000000246,"text":"어떻게 나랑 계속 안 맞아서 여기 못 왔어요..."},{"start":265.4,"duration":1.25,"text":"드디어 먹어본다, 드디어"},{"start":268.65,"duration":2.25,"text":"먹어볼까, 이렇게..."},{"start":270.902,"duration":3.948000000000036,"text":"오징어볶음이랑 짜장면이랑 같이 먹어보겠습니다...!"},{"start":297.15,"duration":2.650000000000034,"text":"와 이거... 진짜 맛있는데?"},{"start":299.802,"duration":3.298000000000002,"text":"매콤한 불 향 짜장면인데"},{"start":303.102,"duration":2.8980000000000246,"text":"먹다 보면 오징어볶음 맛이 나거든요?"},{"start":306.002,"duration":1.4979999999999905,"text":"이거는 맛없없"},{"start":307.502,"duration":1.7479999999999905,"text":"맛이 없을 수 없는 조합이에요"},{"start":326.2,"duration":2.75,"text":"짜장면 약간 느끼해서 못 드시는 분들이"},{"start":328.952,"duration":1.9979999999999905,"text":"드시기엔 너무 좋아하실 것 같아요"},{"start":330.952,"duration":2.298000000000002,"text":"우리는 짬뽕 시켰어요"},{"start":333.252,"duration":2.947999999999979,"text":"잘 먹는 거 찍는 거 아니에요?"},{"start":336.202,"duration":1.447999999999979,"text":"먹방 찍는 거예요??"},{"start":337.652,"duration":1.0980000000000132,"text":"- 네 - 네, 먹방이에요"},{"start":371.85,"duration":1.5499999999999545,"text":"오징어가 잔뜩 들어가 있어요"},{"start":381.85,"duration":1.6999999999999886,"text":"탕수육 나오자마자 먹었어야 했는데..."},{"start":383.552,"duration":1.5480000000000018,"text":"나 바본가 봐..."},{"start":386.55,"duration":1,"text":"식었어"},{"start":392.25,"duration":2.6499999999999773,"text":"'탕수육의 정석' 같은 맛이다"},{"start":394.902,"duration":4.348000000000013,"text":"우리가 아는 그 새콤달콤한, 입맛 돋구는 탕수육"},{"start":418.65,"duration":1.4500000000000455,"text":"제가 봤을 때 이 탕수육은"},{"start":420.102,"duration":2.348000000000013,"text":"푹 적셔서 말랑말랑해졌을 때 맛있는"},{"start":422.452,"duration":1.3980000000000246,"text":"그런 탕수육 같거든요"},{"start":451.6,"duration":1.25,"text":"거의 다 드셨네요ㅎ~"},{"start":455.2,"duration":1.0500000000000114,"text":"박수 한번 치시죠ㅎ"},{"start":456.252,"duration":1.197999999999979,"text":"감사합니다"},{"start":460.052,"duration":2.1479999999999677,"text":"엄청 빨리 먹고 나가시네요"},{"start":462.202,"duration":1.3480000000000132,"text":"지금 다시 좀 한가해졌으니까"},{"start":463.552,"duration":1.0979999999999563,"text":"이제 주문을 해볼까ㅎ?"},{"start":482.4,"duration":1,"text":"사장님"},{"start":483.8,"duration":2.4499999999999886,"text":"짬뽕 하나만 더 부탁드릴게요"},{"start":486.252,"duration":1.0980000000000132,"text":"감사합니다"},{"start":487.352,"duration":3.048000000000002,"text":"아니 이렇게 맛있는 볶음짜장을 두고"},{"start":490.402,"duration":2.098000000000013,"text":"짬뽕을 진짜 많이 시켜서 드시더라고요"},{"start":492.502,"duration":2.048000000000002,"text":"보니까 짬뽕이 진짜 많이 나갔어요, 아까부터"},{"start":494.552,"duration":2.8479999999999563,"text":"가게 이름이 '서유기짬뽕'이네"},{"start":497.402,"duration":2.698000000000036,"text":"그래서 이게... 짜장도 맛있는데"},{"start":500.102,"duration":2.8980000000000246,"text":"뭔가 볶음짬뽕 섞은 맛이 이렇게 메인이 된 게 아닐까?"},{"start":540.1,"duration":3.1000000000000227,"text":"감사합니다, 금방 나왔네"},{"start":543.202,"duration":0.9980000000000473,"text":"엄청 빠르다"},{"start":544.202,"duration":1.4980000000000473,"text":"오징어가 가득 들어가 있네"},{"start":548.102,"duration":2.3980000000000246,"text":"와... 색깔이..."},{"start":550.502,"duration":2.2480000000000473,"text":"오... 냄새가 불 향이..."},{"start":576.55,"duration":2.25,"text":"국물이 깔-끔해요"},{"start":578.801,"duration":3.0989999999999327,"text":"진짜 깔끔한데"},{"start":581.901,"duration":1.399000000000001,"text":"불 향이 진하고"},{"start":583.301,"duration":4.348999999999933,"text":"입에서 감칠맛이 촥- 남아있는?"},{"start":603.15,"duration":3.8500000000000227,"text":"여기 오징어가 약간 특징인가 봐~"},{"start":618,"duration":2.4500000000000455,"text":"피디님이 후추를 뿌려보라고 하시는뎅..."},{"start":620.452,"duration":2.197999999999979,"text":"칼칼해서 안 뿌려도 괜찮을 거 같거든요?"},{"start":622.651,"duration":1.9490000000000691,"text":"넣지 망... 저기 쓰여있길랭..."},{"start":624.602,"duration":0.9479999999999791,"text":"어디 쓰여있어요?"},{"start":628.352,"duration":2.197999999999979,"text":"그럼 제가 한번 먹어보겠습니다"},{"start":630.551,"duration":2.649000000000001,"text":"\"기호에 따라 후추를 첨가하시면 한층 더 깊은 풍미를...\""},{"start":633.202,"duration":0.9479999999999791,"text":"오우 너무 많이 넣었나?!"},{"start":641.95,"duration":1.75,"text":"맛있네~"},{"start":643.702,"duration":2.3980000000000246,"text":"먹다가 뿌리시는 걸 추천드립니다-!"},{"start":659.952,"duration":3.2480000000000473,"text":"이거 먹다 보니까 복분자탕수육 궁금한데?"},{"start":666.05,"duration":5.400000000000091,"text":"저 마지막으로 짜장면 하나랑 복분자탕수육 하나만..."},{"start":671.452,"duration":1.6480000000000246,"text":"- 복분자탕수육 드릴까요? - 네, 감사합니다"},{"start":673.102,"duration":2.7480000000000473,"text":"주변 분들, 동네 분들 많이 오시는 거 같은데"},{"start":675.852,"duration":1.947999999999979,"text":"오늘만 그러는 건지 모르겠는데"},{"start":677.801,"duration":1.5989999999999327,"text":"다들 짬뽕을 드세요"},{"start":679.401,"duration":2.949000000000069,"text":"짬뽕이 완전 압도적 1등 메뉴예요, 지금"},{"start":691.3,"duration":1.8000000000000682,"text":"- 사장님 안녕하세요 - 팬이에요"},{"start":693.102,"duration":1.447999999999979,"text":"정말요? 감사합니다"},{"start":694.551,"duration":1.5489999999999782,"text":"끝내준다"},{"start":696.102,"duration":3.548000000000002,"text":"저희가 전에 서울에서 오징어볶음 장사를 했었어요"},{"start":699.651,"duration":2.8490000000000464,"text":"그러다가 중식도 했었는데, 내려와서"},{"start":702.502,"duration":3.34800000000007,"text":"'오징어볶음에다가 복합을 시켜볼까...?' 해서"},{"start":705.852,"duration":2.548000000000002,"text":"- 제가 최초로 이거를...ㅎ - 아 최초"},{"start":708.401,"duration":2.7490000000000236,"text":"너무 맛있어요, 진짜 최고"},{"start":711.151,"duration":3.049000000000092,"text":"- 이따 사진 좀... - 당연하죠, 당연하죠, 당연하죠!"},{"start":714.202,"duration":2.447999999999979,"text":"탕수육이 너무 특이하거든요"},{"start":716.651,"duration":2.699000000000069,"text":"복분자탕수육이라고... 시뻘건데"},{"start":727.05,"duration":3.900000000000091,"text":"누룽지 맛도 나고..."},{"start":735.25,"duration":2.3500000000000227,"text":"안에... 보이세요? 이거 복분자?"},{"start":737.602,"duration":2.2480000000000473,"text":"일반적인... 우리가 아는..."},{"start":739.852,"duration":4.34800000000007,"text":"뭐, 설탕이나 물엿이나 이런 류의 단맛이었으면"},{"start":744.202,"duration":3.798000000000002,"text":"얘는 진짜 복분자의 과일 단맛이에요"},{"start":748.002,"duration":1.84800000000007,"text":"이거는 조금 나눠주도록 하겠습니다"},{"start":749.852,"duration":3.09800000000007,"text":"왜냐면 지금 다들 이 복분자탕수육을 궁금해해서"},{"start":761.55,"duration":1.9500000000000455,"text":"씨가 씹히는 복분자인데"},{"start":763.502,"duration":1.84800000000007,"text":"진짜 건강한 맛이에요"},{"start":768.3,"duration":1.3000000000000682,"text":"빨리 먹어야 됩니다"},{"start":769.602,"duration":1.09800000000007,"text":"양이 많네"},{"start":771.55,"duration":1.75,"text":"짜장면도 한번"},{"start":776.1,"duration":4.5,"text":"그리고 아까 제가 쟁반짜장 먹어봤을 때"},{"start":780.602,"duration":2.6480000000000246,"text":"짜장면도 맛있을 거 같아요"},{"start":783.252,"duration":2.4980000000000473,"text":"오늘 진짜 날씨 춥거든요?"},{"start":785.752,"duration":1.3980000000000246,"text":"한파예요 한파! 여러분"},{"start":810.3,"duration":2.5,"text":"군만두 위에 짜장면 올린 다음에"},{"start":812.801,"duration":2.74899999999991,"text":"단무지로 감싸서 먹어야 돼"},{"start":816.1,"duration":1.1000000000000227,"text":"군만두 위에"},{"start":818.5,"duration":2.2999999999999545,"text":"짜장면을 감싸서"},{"start":820.802,"duration":1.2980000000000018,"text":"단무지를 올려서 먹으라고?"},{"start":823.55,"duration":1.5500000000000682,"text":"그거야~ 그거야~"},{"start":841.4,"duration":1,"text":"맛있지?"},{"start":846.051,"duration":2.74899999999991,"text":"얘를 같이 넣어서"},{"start":851.6,"duration":0.8500000000000227,"text":"비벼서"},{"start":852.452,"duration":4.548000000000002,"text":"짬뽕 국물 살짝 넣으면"},{"start":857.002,"duration":1.3980000000000246,"text":"아까 이 맛이 날 거 같아요"},{"start":869.2,"duration":2.0499999999999545,"text":"다른 매력이긴 한데 맛있다!"},{"start":888.8,"duration":2.9500000000000455,"text":"소스에 버무려진 채로 그걸 찍어 먹어?"},{"start":891.752,"duration":2.7480000000000473,"text":"소스 묻은 탕수육을 간장에 찍어 먹어야 된대요..."},{"start":895.55,"duration":0.7000000000000455,"text":"찍어서"},{"start":906,"duration":2.8999999999999773,"text":"진짜 맛있다"},{"start":938.2,"duration":1.25,"text":"어우- 잘 먹었다!"},{"start":942.2,"duration":3.75,"text":"제가 먹다가 글이 붙어있는 걸 봤는데"},{"start":945.952,"duration":5.597999999999956,"text":"사장님께서 건강이 조금 안 좋으셔서"},{"start":951.551,"duration":4.24899999999991,"text":"가게를 내놓으셨다는 얘기가 쓰여있더라고요"},{"start":955.801,"duration":3.399000000000001,"text":"가게... 이제 내놓을 생각이시라고..."},{"start":959.202,"duration":0.9479999999999791,"text":"왜 그러냐면요"},{"start":960.151,"duration":1.149000000000001,"text":"작년에..."},{"start":961.301,"duration":1.5489999999999782,"text":"제가 다리가 골절되고"},{"start":962.852,"duration":3.298000000000002,"text":"그래서 와이프도 한 석 달을 쉬었어요"},{"start":970.202,"duration":1.6480000000000246,"text":"쉽게 나가진 않을 거예요"},{"start":979.102,"duration":2.298000000000002,"text":"- 정말 팬이에요! 진짜...! - 감사합니다"},{"start":981.401,"duration":5.449000000000069,"text":"쯔양 님 가신 곳 저도 맛집 돌아다니고 있어요"},{"start":986.852,"duration":4.947999999999979,"text":"사장님) 솔직하게... 편집을 어떻게 하는 건가?"},{"start":991.801,"duration":2.6989999999999554,"text":"저런 체구에... 어떻게 다 드시나..."},{"start":994.502,"duration":3.1480000000000246,"text":"너무 맛있게 잘 먹어서 인사드리고 싶었습니다"},{"start":998.952,"duration":3.798000000000002,"text":"얼른 건강하게 쾌차하셨으면 하는 마음입니다"},{"start":1002.752,"duration":1.9480000000000928,"text":"전체적으로 좀 특이한 음식이 많았어요"},{"start":1004.702,"duration":2.0979999999999563,"text":"복분자탕수육도 되게 특이했고..."},{"start":1006.801,"duration":2.6989999999999554,"text":"짜장면에다 오볶 하는 집은..."},{"start":1009.502,"duration":2.09800000000007,"text":"사장님이 최초라고 하셨으니까..."},{"start":1011.602,"duration":2.59800000000007,"text":"세상에 제가 안 먹어본 게 너무 많네요...!"},{"start":1014.202,"duration":1.7980000000000018,"text":"다 먹어보는 날까지...!"},{"start":1016.002,"duration":1.9980000000000473,"text":"먹방을 계속할 수 있을지..."},{"start":1018.002,"duration":2.34800000000007,"text":"마무리) 열심히 해보도록 하겠습니다ㅎㅎ"},{"start":1020.352,"duration":4.197999999999979,"text":"오늘도 잘 먹었습니다~!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
