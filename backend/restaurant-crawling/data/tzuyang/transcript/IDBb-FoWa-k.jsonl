ration":2.5299999999999727,"text":"얘는 확실히 채수 맛이 많이 나요"},{"start":700.275,"duration":1.4640000000000555,"text":"확실히 다르네"},{"start":702.289,"duration":4.18100000000004,"text":"이런 게 맛있다구요"},{"start":712.564,"duration":2.7789999999999964,"text":"뭐야? 후추가 있었던 걸 왜 말 안 해줬어요?"},{"start":715.862,"duration":1.3960000000000719,"text":"칼국수에는 후추지"},{"start":717.934,"duration":1.9370000000000118,"text":"아 국물이 다를 것 같은데...?"},{"start":719.872,"duration":2.5,"text":"왜 후추를 안 쳐서 먹었을까..."},{"start":723.952,"duration":2.6299999999999955,"text":"갑자기 해장 칼국수가 됐다"},{"start":727.131,"duration":1.1600000000000819,"text":"제가 사실 원래..."},{"start":728.293,"duration":2.0670000000000073,"text":"칼국수에 김치 올려 먹는 거 별로 안 좋아하거든요"},{"start":730.362,"duration":1.875,"text":"왜냐면은..."},{"start":732.238,"duration":1.5639999999999645,"text":"맛을 해치기 때문입니다"},{"start":733.804,"duration":2.63900000000001,"text":"하지만 김치가 맛있으니까 먹어야지"},{"start":752.128,"duration":3.826999999999998,"text":"여기다 수제비 하나 딱 싸서"},{"start":770.706,"duration":1.6589999999999918,"text":"아니 근데..."},{"start":772.635,"duration":2.243000000000052,"text":"이러면 칼제비가 완전 이득 아닌가?"},{"start":774.88,"duration":1.983000000000061,"text":"왜냐면 사실 수제비도 5,000원이고"},{"start":776.865,"duration":0.9650000000000318,"text":"칼국수도 5,000원이고"},{"start":777.832,"duration":2.0120000000000573,"text":"칼제비도 5,000원이거든요?"},{"start":779.846,"duration":2.076000000000022,"text":"근데 수제비는 이 그릇에 나온대요"},{"start":781.924,"duration":2.064000000000078,"text":"근데 두 가지 같이 먹을 수 있으니까"},{"start":783.99,"duration":1.907000000000039,"text":"이게 이득 아닐까...?"},{"start":819.583,"duration":2.8780000000000427,"text":"제가 오늘은 간단히 먹을 거거든요"},{"start":822.463,"duration":1.893000000000029,"text":"입가심용으로..."},{"start":824.358,"duration":2.2450000000000045,"text":"잔치국수를 마지막으로 먹어볼게요, 왜냐면"},{"start":826.604,"duration":5.557999999999993,"text":"진짜 깔끔하고 개운해서 마지막 피날레로 잘 어울릴 거 같아요"},{"start":833.779,"duration":1.5299999999999727,"text":"벌써 나왔어, 감사합니다"},{"start":835.31,"duration":4.396000000000072,"text":"와 마지막은 인심이 가득이다"},{"start":840.479,"duration":1.1929999999999836,"text":"양이 진짜..."},{"start":842.165,"duration":1.6020000000000891,"text":"거짓말처럼 많네"},{"start":860.539,"duration":2.3899999999999864,"text":"이야 이게 지금 2만 원이 안 되네"},{"start":862.93,"duration":1.025000000000091,"text":"이게요?"},{"start":863.957,"duration":1.032000000000039,"text":"5,000원"},{"start":864.991,"duration":1.5950000000000273,"text":"만 원, 만 5,000원"},{"start":867.757,"duration":3.2840000000001055,"text":"만 9,000원?! 진짜 싸다"},{"start":897.548,"duration":2.1620000000000346,"text":"- 맛있게 드셨어요? - 네, 너무 맛있어요"},{"start":899.712,"duration":1.6119999999999663,"text":"어떻게 이게..."},{"start":901.325,"duration":2.4309999999999263,"text":"가격이 이런데 어떻게 이렇게 양을 많이 주세요?"},{"start":903.757,"duration":2.177000000000021,"text":"박리다매"},{"start":905.935,"duration":2.157000000000039,"text":"지금 여기가 23년 됐는데"},{"start":908.093,"duration":1.6870000000000118,"text":"처음부터 그렇게 시작을 한 거예요"},{"start":909.781,"duration":2.715000000000032,"text":"와 그럼 하루에 몇 그릇 정도 나가요...?"},{"start":912.497,"duration":1.5480000000000018,"text":"토요일, 일요일은"},{"start":914.046,"duration":1.9499999999999318,"text":"1,000그릇이 좀 넘고"},{"start":915.997,"duration":2.8010000000000446,"text":"그리고 우리는 진짜 솔직히 말해서 별거 안 들어가요"},{"start":918.8,"duration":3.425000000000068,"text":"- 순수하게 멸치예요 - 근데 한 10시간 우린 것 같아요"},{"start":922.718,"duration":2.799000000000092,"text":"쯔양 씨가 이렇게 맛있게 먹어줬다니까 고마워요ㅎㅎ"},{"start":925.519,"duration":3.4020000000000437,"text":"사실 너무 맛있어서 더 먹고 싶은데"},{"start":928.923,"duration":1.8179999999999836,"text":"여기 영업시간도 다 끝났어요"},{"start":932.197,"duration":3.062999999999988,"text":"라스트 오더 끝났다"},{"start":935.262,"duration":2.243000000000052,"text":"집에 가야겠네...?"},{"start":937.507,"duration":2.6170000000000755,"text":"'손님이 다들 어디 가셨지...?' 했는데"},{"start":940.126,"duration":1.6560000000000628,"text":"영업시간이 끝나가고 있었어요"},{"start":941.784,"duration":2.643000000000029,"text":"와 어떻게 이런 집이 있을까 싶어요"},{"start":944.429,"duration":2.574000000000069,"text":"사장님이 계속 건강하셔서"},{"start":947.005,"duration":2.4869999999999663,"text":"맛있는 음식 계속해 주셨으면 좋겠습니다"},{"start":949.493,"duration":1.0709999999999127,"text":"아무튼 오늘도"},{"start":950.565,"duration":2.617999999999938,"text":"잘 먹었습니다~!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
