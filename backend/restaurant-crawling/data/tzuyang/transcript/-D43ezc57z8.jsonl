.102,"duration":2.5679999999999836,"text":"일단 낙지볶음이 원래 달잖아요"},{"start":802.671,"duration":0.7289999999999281,"text":"근데 여긴 진짜"},{"start":803.401,"duration":1.9390000000000782,"text":"단맛 자체가 거의 없어서 좋았고"},{"start":805.342,"duration":3.447999999999979,"text":"마지막까지 짜지 않게 먹을 수 있는 양념이라서"},{"start":808.791,"duration":2.758999999999901,"text":"마지막까지 질리지 않고 맛있게 먹었습니다"},{"start":811.551,"duration":3.798999999999978,"text":"봄에 낙지가 3배만 하면 봄에 한 번 더 와야겠는데?"},{"start":815.352,"duration":1.5360000000000582,"text":"아무튼 맛있게 잘 먹었습니다"},{"start":816.89,"duration":1.240000000000009,"text":"오늘도"},{"start":818.132,"duration":3.9680000000000746,"text":"잘 먹었습니다~!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
