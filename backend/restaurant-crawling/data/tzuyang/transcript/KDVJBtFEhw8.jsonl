text":"마이 파전~"},{"start":1021.502,"duration":1.84800000000007,"text":"아껴놨는데! 괜히 아꼈어"},{"start":1031.45,"duration":1.6499999999998636,"text":"엄청 빨리 먹었어요"},{"start":1033.101,"duration":1.5989999999999327,"text":"순식간에 해치웠습니다"},{"start":1034.702,"duration":1.3979999999999109,"text":"굴 철 지나기 전에"},{"start":1036.101,"duration":2.2489999999997963,"text":"다들 굴 꼭 드시고!"},{"start":1038.351,"duration":1.3489999999999327,"text":"굴 보신 하시고ㅎㅎ"},{"start":1039.702,"duration":1.8979999999999109,"text":"올겨울에 여러분들도"},{"start":1041.601,"duration":4.698999999999842,"text":"맛있는 굴찜 놓치지 않고 드셨으면 좋겠습니다"},{"start":1046.301,"duration":3.8990000000001146,"text":"오늘도 잘 먹었습니다~!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
