00000691,"text":"간장 살짝"},{"start":653,"duration":1,"text":"인어공주 같아"},{"start":680.25,"duration":1.8500000000000227,"text":"굴 되게 많이 먹어봤잖아요"},{"start":682.102,"duration":3.197999999999979,"text":"한국 굴이 향이 엄청 센 편이에요"},{"start":685.301,"duration":6.24899999999991,"text":"해외 굴은 전체적으로 맛이 약한 편이고"},{"start":691.551,"duration":2.798999999999978,"text":"한국 굴은 약간 눅진해요"},{"start":694.352,"duration":3.9980000000000473,"text":"향도, 맛도, 감칠맛도, 짭짤함도 세고"},{"start":698.352,"duration":2.197999999999979,"text":"해외 굴은 오히려 좀..."},{"start":700.551,"duration":2.649000000000001,"text":"비린 거 못 드시는 분들도 잘 드실 수 있을 것 같은데"},{"start":707.8,"duration":1.6000000000000227,"text":"얘는 장난 아니다"},{"start":712.95,"duration":1.25,"text":"너무 이쁘잖아"},{"start":718.15,"duration":2.050000000000068,"text":"그거 먹을까...?"},{"start":720.202,"duration":2.447999999999979,"text":"제가 굴전은 진짜 많이 봤거든요"},{"start":722.651,"duration":1.6990000000000691,"text":"굴김치전은 처음 봐요"},{"start":724.352,"duration":1.3980000000000246,"text":"굴김치전이 많이 나가나요?"},{"start":725.752,"duration":1.1980000000000928,"text":"굴파전이 많이 나가나요?"},{"start":726.952,"duration":2.298000000000002,"text":"- 취향 차이라서 반반으로 나가고 있어요 - 아 그래요?"},{"start":729.252,"duration":1.4480000000000928,"text":"안 먹어봐서, 굴김치전으로"},{"start":730.702,"duration":0.7980000000000018,"text":"감사합니다"},{"start":752.25,"duration":3.8999999999999773,"text":"우와 엄청 크다, 감사합니다"},{"start":756.151,"duration":1.899000000000001,"text":"- 이렇게 놓고 먹나요? - 네네"},{"start":758.051,"duration":1.24899999999991,"text":"감사합니다"},{"start":759.302,"duration":1.8980000000000246,"text":"왜 이렇게 커? 나 이렇게 클 줄 몰랐는데"},{"start":761.202,"duration":2.3479999999999563,"text":"여기 장사하신 지 얼마나 되셨어요?"},{"start":763.551,"duration":3.5989999999999327,"text":"제가 한 건 이제 3년 정도 돼가요"},{"start":767.151,"duration":3.5990000000000464,"text":"- 아~ 물려받으신 거예요? - 네! 물려받았는데"},{"start":770.752,"duration":2.6480000000000246,"text":"제가 여기서는 쭉 했습니다! 정식적으로"},{"start":773.401,"duration":2.449000000000069,"text":"와 20대... 25살..."},{"start":775.852,"duration":1.34