{"youtube_link":"https://www.youtube.com/watch?v=8kE5Uq_YV08","channel_name":"tzuyang","language":"ko","collected_at":"2026-02-27T04:53:55.138+09:00","transcript":[{"start":4.753,"duration":1.952,"text":"안녕하세요 여러분"},{"start":6.707,"duration":1.2080000000000002,"text":"제가 오늘은!"},{"start":7.917,"duration":2.2110000000000003,"text":"1일 직장인이 되기로 했거든요"},{"start":10.13,"duration":2.8739999999999988,"text":"일단 굉장히 좋은 곳에 취직이 됐어요-!"},{"start":13.006,"duration":2.9239999999999995,"text":"우리은행 직원이 되러 왔습니다"},{"start":15.932,"duration":7.485000000000001,"text":"으리으리"},{"start":23.419,"duration":1.7959999999999994,"text":"이쪽으로 가면 명동이고"},{"start":25.217,"duration":2.0080000000000027,"text":"이쪽으로 가면 남대문이라서"},{"start":27.227,"duration":1.4289999999999985,"text":"일단 맛집이 많아요"},{"start":28.657,"duration":2.908999999999999,"text":"점심시간에 아주 맛있는 걸 먹을 예정이거든요"},{"start":31.567,"duration":3.7409999999999997,"text":"선배님들한테 추천을 받아서 갈 건데"},{"start":35.31,"duration":2.225999999999999,"text":"그리고 여기가 또 참 좋은 게"},{"start":37.538,"duration":1.4890000000000043,"text":"바로 앞에 신세계 본점이 있네요-!"},{"start":39.029,"duration":2.814,"text":"겨울만 되면 완전 포토 스폿인데"},{"start":41.845,"duration":2.169000000000004,"text":"여기 푸드 코트에 먹을 게 진짜 많거든요"},{"start":44.536,"duration":1.064,"text":"맛있겠다"},{"start":45.602,"duration":2.3160000000000025,"text":"출근했는데 먹는 생각밖에 안 나네"},{"start":47.92,"duration":0.8279999999999959,"text":"일단"},{"start":48.75,"duration":3.075000000000003,"text":"오늘은 첫날이니까 제 맘대로"},{"start":51.827,"duration":1.3070000000000022,"text":"건물을 좀 이렇게"},{"start":53.136,"duration":2.1400000000000006,"text":"돌아다녀 보도록 하겠습니다"},{"start":55.278,"duration":3.736000000000004,"text":"제가 유튜브 아니었으면 언제 대기업에 취업해 보겠어요"},{"start":62.055,"duration":2.1669999999999945,"text":"선배님들 찾으러 일단 지하로 내려가 볼까"},{"start":64.223,"duration":2.7860000000000014,"text":"와... 지하 1층에 스타벅스가 있네..."},{"start":67.011,"duration":3.4200000000000017,"text":"대기업은 다른데?"},{"start":76.798,"duration":2.6359999999999957,"text":"저기 그레이트 라운지에서 보기로 했는데..."},{"start":81.536,"duration":2.7620000000000005,"text":"쉼터구나, 엄청 잘돼있네?"},{"start":84.76,"duration":2.85799999999999,"text":"- 안녕하세요 - 안녕하세요"},{"start":87.619,"duration":2.1099999999999994,"text":"- 어?! 출입증!! - 우리은행 직원 되신 걸 환영합니다ㅎㅎ"},{"start":89.731,"duration":1.078000000000003,"text":"감사합니다!!"},{"start":90.811,"duration":3.875,"text":"입사 기준이요? 잘 먹어야 됩니다"},{"start":94.688,"duration":3.707000000000008,"text":"입사 기념 선물로 저희가 특별히 준비했습니다"},{"start":98.396,"duration":1.1550000000000011,"text":"감사합니다"},{"start":99.553,"duration":2.9509999999999934,"text":"저희 국가대표 선수분들께 드리는"},{"start":102.506,"duration":2.290999999999997,"text":"동계 올림픽 특별 굿즈인데!"},{"start":104.798,"duration":0.8460000000000036,"text":"아 정말요?"},{"start":105.646,"duration":2.3740000000000094,"text":"추우실 때 유용하게 쓰실 수 있을 거예요"},{"start":108.021,"duration":1.86399999999999,"text":"너무 감사합니다~!"},{"start":109.887,"duration":0.7369999999999948,"text":"여기는"},{"start":110.625,"duration":1.9509999999999934,"text":"'그레이트 라운지'라고 해서"},{"start":112.577,"duration":2.1159999999999997,"text":"직원들도 사용할 수 있고"},{"start":114.695,"duration":2.6260000000000048,"text":"당연히 고객님들도 다 사용할 수 있는"},{"start":117.32300000000001,"duration":1.641999999999996,"text":"- 그런 열린 공간입니다 - 같이"},{"start":118.967,"duration":1.8769999999999953,"text":"아 그럼 오늘 하실 일은!"},{"start":120.845,"duration":2.6410000000000053,"text":"우리은행 1일 직원이 되신 만큼!"},{"start":123.488,"duration":2.305000000000007,"text":"우리은행을 알려주셨으면 해요"},{"start":125.795,"duration":2.7679999999999865,"text":"- 알겠습니다 - 일일 홍보 대사로, 적극적으로"},{"start":128.565,"duration":1.884999999999991,"text":"잘 열심히 해보겠습니다"},{"start":130.452,"duration":2.6129999999999995,"text":"누구나 편하게 쉴 수 있게"},{"start":133.067,"duration":1.7319999999999993,"text":"자리가 엄청 넓다"},{"start":137.168,"duration":1.9849999999999852,"text":"이번에"},{"start":139.155,"duration":3.0180000000000007,"text":"밀라노, 코르티나에서 그 동계 올림픽 하거든요?"},{"start":142.175,"duration":1.5419999999999732,"text":"많은 관심 부탁드립니다"},{"start":143.719,"duration":1.524000000000001,"text":"공식 후원사"},{"start":147.443,"duration":2.3819999999999766,"text":"귀마개다, 이건 좀 이따 해야겠다"},{"start":149.827,"duration":1.975999999999999,"text":"위비 키링이고요"},{"start":151.805,"duration":1.9010000000000105,"text":"- 위비라고 - 아 우리은행"},{"start":153.708,"duration":2.938999999999993,"text":"우리은행 공식 캐릭터구나"},{"start":156.649,"duration":2.865000000000009,"text":"티백 홀더, 너무 귀엽다"},{"start":163.287,"duration":3.5960000000000036,"text":"감사합니다"},{"start":166.885,"duration":1.2680000000000007,"text":"제가..."},{"start":168.155,"duration":1.967000000000013,"text":"출근을 좀 늦게 해서..."},{"start":170.124,"duration":2.919000000000011,"text":"배가 좀 많이 고픈데, 혹시..."},{"start":173.04500000000002,"duration":3.018999999999977,"text":"점심시간을 먼저 갔다 와도 될까요?"},{"start":176.066,"duration":1.3839999999999861,"text":"지금 점심시간이거든요"},{"start":177.452,"duration":2.0900000000000034,"text":"배고프면 일을 잘 못 하시니까ㅎㅎ..."},{"start":179.54399999999998,"duration":1.1210000000000093,"text":"와서 열심히 하겠습니다!"},{"start":180.667,"duration":2.6299999999999955,"text":"맛있는 곳 추천을 해주시면..."},{"start":183.299,"duration":3.705999999999989,"text":"'만만'이라고 여기 옆에 조그마한 중식당 있는데"},{"start":187.007,"duration":1.4699999999999989,"text":"'만만' 중식"},{"start":188.47899999999998,"duration":2.1350000000000193,"text":"어떡해, 첫날부터 뭐 먹어야 되나?"},{"start":190.61599999999999,"duration":3.8740000000000236,"text":"첫날이지만 점심시간을 즐기고 오겠습니다"},{"start":202.294,"duration":2.5589999999999975,"text":"제가 출근을 좀 늦게 해서"},{"start":204.855,"duration":2.834000000000003,"text":"출근하자마자 점심을 먹으러 나왔습니다"},{"start":207.691,"duration":2.162000000000006,"text":"뭘 먹을지 고민을 진짜 많이 하다가"},{"start":209.855,"duration":1.3290000000000077,"text":"맛집 추천을 받았는데"},{"start":211.186,"duration":2.367999999999995,"text":"정말 많은 맛집을 추천 많이 해주셨거든요"},{"start":213.55599999999998,"duration":4.217000000000013,"text":"근처에 점심 식사하러 많이 가시죠?"},{"start":218.303,"duration":3.6920000000000073,"text":"'갈비명가이상'이라고 있는데 갈비탕이 진짜 맛있어요"},{"start":221.997,"duration":3.5149999999999864,"text":"'화떡'이라고 곱창떡볶이가 유명하죠"},{"start":225.514,"duration":2.822999999999979,"text":"'윤요연'이라고 아시아 퓨전 음식 파는 덴데"},{"start":228.339,"duration":2.384999999999991,"text":"거기 정말 맛있습니다, 추천드려요"},{"start":230.726,"duration":1.3100000000000023,"text":"'향미' 가보셨어요?"},{"start":232.038,"duration":1.531000000000006,"text":"'향미'도 진짜 맛있고"},{"start":233.571,"duration":1.8029999999999973,"text":"- '쯔루하시 후게츠' - 오코노미야키"},{"start":235.376,"duration":1.1589999999999918,"text":"오코노미야키입니다"},{"start":236.535,"duration":4.920000000000016,"text":"카메라 끄고 계속 오는 내내 어디가 맛있는지 여쭤봤는데"},{"start":241.457,"duration":2.9410000000000025,"text":"여기가 추천을 두 번 정도 받은 곳이에요"},{"start":244.4,"duration":2.0730000000000075,"text":"추천받은 곳 중에서 직장인 맛집에 정말 걸맞은 거 같아서"},{"start":246.475,"duration":2.4780000000000086,"text":"양도 많고 가성비 좋고"},{"start":248.955,"duration":4.441999999999979,"text":"좀 간단하고 편하게 먹을 수 있는 분식들이 있다고 해서"},{"start":253.399,"duration":0.48099999999999454,"text":"그리고"},{"start":253.882,"duration":2.5149999999999864,"text":"개인적으로 수제비가 너무 먹고 싶었어요"},{"start":256.399,"duration":1.646000000000015,"text":"제가 또 수제비 엄청 좋아하잖아요"},{"start":258.047,"duration":3.2469999999999573,"text":"우리은행에서 명동 쪽으로 쭉 내려왔거든요"},{"start":261.296,"duration":3.965000000000032,"text":"여기 '명동 얼큰수제비'"},{"start":265.263,"duration":3.382000000000005,"text":"생각해 보면 지금 점심시간이 1시간이잖아요"},{"start":268.647,"duration":2.6370000000000005,"text":"나 어떡해?"},{"start":271.286,"duration":1.646000000000015,"text":"좀 늦게 가도 되지 않을까?"},{"start":272.93399999999997,"duration":3.198000000000036,"text":"어떡하지? 일단 빨리 가야겠다"},{"start":277.229,"duration":3.055999999999983,"text":"- 안녕하세요~ - 안녕하세요~"},{"start":280.287,"duration":2.7940000000000396,"text":") 오늘 우리은행 직원이에요"},{"start":285.471,"duration":1.4519999999999982,"text":"수제비가 메인이네~"},{"start":287.36,"duration":2.6549999999999727,"text":"그리고 떡볶이, 떡볶이도 맛있겠다"},{"start":290.017,"duration":1.5550000000000068,"text":"회사원 같아~"},{"start":291.574,"duration":1.1469999999999914,"text":"저 회사원 같죠ㅎㅎ"},{"start":293.904,"duration":1.1920000000000073,"text":"빨리 먹고 들어갈 겁니다"},{"start":299.121,"duration":2.4820000000000277,"text":"사장님 여기 이렇게 주세요-!"},{"start":301.605,"duration":0.83299999999997,"text":"이렇게 많이?"},{"start":302.44,"duration":1.7269999999999754,"text":"- 이걸 혼자 드셔요??? - 네, 혼자 먹으려고요"},{"start":304.169,"duration":1.9390000000000214,"text":"으하하하..."},{"start":352.516,"duration":1.728999999999985,"text":"일단 불기 전에 라면부터 먹겠습니다"},{"start":354.247,"duration":3.26400000000001,"text":"여기 하나만 뭐 더 시키고 싶은데, 약간 모자랄 거 같은데?"},{"start":357.513,"duration":1.9750000000000227,"text":"불기 전에 라면부터 빨리"},{"start":359.49,"duration":2.2439999999999714,"text":"분식집에선 역시 라면이지"},{"start":385.654,"duration":1.120999999999981,"text":"좋다"},{"start":394.598,"duration":1,"text":"너무 좋다"},{"start":397.869,"duration":1.061999999999955,"text":"와아- 수제비!"},{"start":398.933,"duration":1.7090000000000032,"text":"제가 딱 좋아하는 손수제비예요"},{"start":400.644,"duration":1.61099999999999,"text":"이게 수제비지~!"},{"start":402.579,"duration":0.7690000000000055,"text":"너무 맛있겠다"},{"start":403.35,"duration":2.1429999999999723,"text":"안에 김치도 있고 얼큰이라서"},{"start":410.016,"duration":3.233000000000004,"text":"김치수제비와 장칼국수 반반 섞은 맛?"},{"start":413.251,"duration":1.5260000000000105,"text":"시원하니 맛있네~"},{"start":419.447,"duration":1.6159999999999854,"text":"양이 많네"},{"start":423.889,"duration":1.3379999999999654,"text":"와 이거는..."},{"start":425.229,"duration":0.9230000000000018,"text":"2배다"},{"start":426.154,"duration":3.5230000000000246,"text":"일반 김치볶음밥의 2배 정도 되는 거 같은데?"},{"start":429.679,"duration":1.6510000000000105,"text":"양 진짜 많아요"},{"start":431.332,"duration":2.434000000000026,"text":"- 사장님께서 워낙 손이 크셔서... - 아~~ 정말요?"},{"start":433.76800000000003,"duration":1.4159999999999968,"text":"원래 이렇게 밥을 많이 주세요?"},{"start":435.186,"duration":2.448000000000036,"text":"- 원래 양이 좀 많아요ㅎㅎ - 그래요?"},{"start":437.636,"duration":0.9849999999999568,"text":"쪼끔 작은 건뎅..."},{"start":438.623,"duration":1.8059999999999832,"text":"이게 작은 거예요?!"},{"start":440.431,"duration":2.6759999999999877,"text":"많이 달라고 하면 더 주고 있어요ㅎㅎ"},{"start":443.109,"duration":7.963999999999999,"text":"직장인 분들 많이 오시죠?"},{"start":451.075,"duration":1.079999999999984,"text":"너무 좋아요"},{"start":452.157,"duration":1.254000000000019,"text":"근데 맛있어요"},{"start":462.152,"duration":2.098000000000013,"text":"여기다 김 가루 살짝 비벼서"},{"start":472.373,"duration":1.6440000000000055,"text":"와 여기 김치볶음밥 맛있다...~!"},{"start":474.019,"duration":1.8079999999999927,"text":"음식도 진짜 금방 나오고"},{"start":475.829,"duration":2.0009999999999764,"text":"바쁜 직장인 분들은 양도 많고 딱 좋을 것 같아요"},{"start":484.464,"duration":1.5539999999999736,"text":"겨울에 오기 진짜 최고인데"},{"start":486.02,"duration":1.9530000000000314,"text":"참치김밥 라면에 찍어서..."},{"start":498.832,"duration":1.891999999999996,"text":"멸치김밥 궁금한데?"},{"start":500.726,"duration":1.2139999999999986,"text":"멸치가 빨개요"},{"start":507.165,"duration":2.0509999999999877,"text":"씹는 느낌은 안 나고 멸치가 약간 부드러운 김밥?"},{"start":514.769,"duration":2.73599999999999,"text":"개인적인 취향으론 참치김밥 승-!"},{"start":539.341,"duration":1.8450000000000273,"text":"집에서 만든 김치볶음밥인데"},{"start":541.188,"duration":2.685000000000059,"text":"엄마가 되게 맛있게 해준 김치볶음밥 맛이에요"},{"start":543.875,"duration":2.5370000000000346,"text":"우리 엄마 김치볶음밥이랑 맛이 비슷한 거 같기도 하고"},{"start":546.414,"duration":1.6370000000000573,"text":"여기다 훈제 오리 넣으면"},{"start":548.053,"duration":3.2069999999999936,"text":"옛날에 우리 집에서 해 먹던 김치볶음밥이랑 맛 똑같겠다"},{"start":556.887,"duration":2.6690000000000964,"text":"이렇게 하루에 점심 먹으면..."},{"start":559.558,"duration":2.25,"text":"월급이 안 남아나겠는데?"},{"start":561.81,"duration":2.574000000000069,"text":"내가 먹방 유튜버가 아니었다면..."},{"start":564.386,"duration":5.5779999999999745,"text":"직장인 생활도 하고 프리랜서도 하고 이것저것 뭔가 하다가"},{"start":569.966,"duration":2.7060000000000173,"text":"결국 식비 때문에 감당을 못하고"},{"start":572.674,"duration":2.910000000000082,"text":"삶을...) 호텔 뷔페나 이런 데서 일하지 않았을까요?"},{"start":575.585,"duration":4.7439999999999145,"text":"호텔 매니저까지 올라가면 그래도 좀 가져갈..."},{"start":581.73,"duration":2.1960000000000264,"text":"이게 대략 얼마야?"},{"start":583.928,"duration":0.7889999999999873,"text":"3만 4,000원-!"},{"start":584.