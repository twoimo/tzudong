{"youtube_link":"https://www.youtube.com/watch?v=099Wx01_5aQ","channel_name":"tzuyang","language":"ko","collected_at":"2026-02-27T04:53:42.117+09:00","transcript":[{"start":0.002,"duration":0.99,"text":"제가 좀 조개를"},{"start":0.994,"duration":1.914,"text":"사랑해서 왔습니다"},{"start":5.88,"duration":3.000000000000001,"text":"혼자 대짜 시켜서 드시는 분은 없어서"},{"start":38.483,"duration":1.9670000000000059,"text":"안녕하세요 여러분"},{"start":40.452,"duration":1.0230000000000032,"text":"제가 오늘은"},{"start":41.477,"duration":2.531000000000006,"text":"지금 아까 삽교에서"},{"start":44.01,"duration":2.0990000000000038,"text":"이제 아침에 짜장면 먹고"},{"start":46.111,"duration":1.4209999999999994,"text":"조개구이 먹으러 왔습니다!"},{"start":47.534,"duration":2.727000000000004,"text":"삽교에는 조개구이집이 너무 많더라고요"},{"start":50.263,"duration":2.375,"text":"노포스럽고"},{"start":52.64,"duration":1.7719999999999985,"text":"규모가 그렇게 크지 않고"},{"start":54.414,"duration":3.463000000000001,"text":"제가 좀 원하는 그런 조개구이집에 왔습니다"},{"start":57.879,"duration":2.4179999999999993,"text":"짠! 저기예요, '조개사랑'"},{"start":60.299,"duration":2.142000000000003,"text":"21년 정도 됐다고 하더라고요"},{"start":62.443,"duration":1.0090000000000003,"text":"제가 좀 조개를"},{"start":63.454,"duration":1.6739999999999995,"text":"사랑해서 왔습니다"},{"start":65.128,"duration":1.7849999999999966,"text":"진짜 조개 너무 좋아하거든요"},{"start":66.914,"duration":1.593999999999994,"text":"벌써 먹을 생각에 너무 설레!"},{"start":68.509,"duration":1.0919999999999987,"text":"사실 이번에 저희 가든즈에서"},{"start":69.603,"duration":1.2620000000000005,"text":"모자가 나왔는데"},{"start":70.866,"duration":2.576999999999998,"text":"사실 제가 모자를 진짜 많이 써요"},{"start":73.445,"duration":1.1020000000000039,"text":"촬영할 때 말고는"},{"start":74.548,"duration":3.0829999999999984,"text":"밖에 나갈 땐 항상 매일매일 모자를 쓰고 다니는데"},{"start":77.633,"duration":2.206000000000003,"text":"색깔별로 맞춰서 쓰는 걸 좋아하는데"},{"start":79.84,"duration":1.9749999999999943,"text":"색깔이 엄청 많은 게 없더라고요"},{"start":81.81700000000001,"duration":2.4069999999999965,"text":"제가 좋아하는 색깔 다 해서"},{"start":84.226,"duration":1.7369999999999948,"text":"엄청 많은 색깔로 만들었어요"},{"start":85.964,"duration":0.8640000000000043,"text":"그리고"},{"start":86.83,"duration":1.644999999999996,"text":"제 취향대로 만들었거든요?!"},{"start":88.476,"duration":3.379000000000005,"text":"대두 볼캡이라고 들어보신 분 계시겠지만"},{"start":91.857,"duration":2.0200000000000102,"text":"여자분이 썼을 땐"},{"start":93.878,"duration":2.6640000000000015,"text":"머리가 다 가려지는 정도의 크기"},{"start":96.544,"duration":2.2730000000000103,"text":"그래서 남성분들이 써도"},{"start":98.818,"duration":2.219999999999999,"text":"'어? 좀 크네?' 할 정도의 크기로"},{"start":101.039,"duration":3.024000000000001,"text":"완전 이렇게 대두 볼캡을 만들었습니다!"},{"start":104.065,"duration":2.0990000000000038,"text":"화장 안 했을 때 딱 쓰기 좋은!"},{"start":106.166,"duration":2.3760000000000048,"text":"제 취향의 모자를 만들었습니다!"},{"start":108.544,"duration":1.3440000000000083,"text":"엄청 크죠?"},{"start":109.89,"duration":2.1970000000000027,"text":"얼굴이 작아 보이는 효과가 있습니다!"},{"start":112.089,"duration":2.4399999999999977,"text":"하여튼 들어가 볼게요"},{"start":115.00200000000001,"duration":1.8559999999999945,"text":"춥다, 날씨가 진짜..."},{"start":116.86,"duration":1.4899999999999949,"text":"대체 오늘 영하 몇 °c야?"},{"start":118.351,"duration":7.778000000000006,"text":"안녕하세요"},{"start":126.131,"duration":1.6479999999999961,"text":"혼자 오시는 분이 거의 없어요?"},{"start":127.78,"duration":2.038000000000011,"text":"- 그르쵸 - 보통은 몇 인분 드세요?"},{"start":129.82,"duration":2.0049999999999955,"text":"보통 소짜 두 분, 세 분..."},{"start":131.827,"duration":1.4230000000000018,"text":"- 소짜? - 네"},{"start":133.252,"duration":3.6149999999999807,"text":"혼자 대짜 시켜서 드시는 분은 없어서"},{"start":136.869,"duration":2.9650000000000034,"text":"- 대짜 보통 양이 어느 정도 나와요? - 보통 세 분~네 분 드시기는 하는데..."},{"start":139.836,"duration":2.220999999999975,"text":"대짜리가 세 분~네 분이요?"},{"start":142.059,"duration":5.143000000000001,"text":"저걸 서너 명이 먹을 수 있나?"},{"start":147.204,"duration":4.555999999999983,"text":"그럼 조개구이 대짜리로 한 3개 시킬까요?"},{"start":151.762,"duration":0.9170000000000016,"text":"어떻게 생각하세요?"},{"start":152.68099999999998,"duration":0.757000000000005,"text":"3개요...?ㅋㅎㅎ"},{"start":153.44,"duration":3.3930000000000007,"text":"하나 먼저 해드리고"},{"start":156.835,"duration":0.7889999999999873,"text":"감사합니다"},{"start":181.493,"duration":1.804000000000002,"text":"조개가 이렇게 나오네?"},{"start":185.041,"duration":1.5409999999999968,"text":"잘 먹겠습니다~!"},{"start":186.584,"duration":1.2690000000000055,"text":"대박! 기대돼"},{"start":187.855,"duration":2.4579999999999984,"text":"여기 있는 키조개 먼저 하나..."},{"start":190.315,"duration":3.9310000000000116,"text":"쌰악 올리고-!"},{"start":195.206,"duration":2.2590000000000146,"text":"2개 올리고"},{"start":198.179,"duration":1.0859999999999843,"text":"그리고"},{"start":199.791,"duration":2.313999999999993,"text":"요것도 하나 올리고, 하나씩 올려야지"},{"start":202.107,"duration":2.109000000000009,"text":"전복도 하나 올리고"},{"start":208.054,"duration":0.9890000000000043,"text":"와 화력 진짜 세!"},{"start":209.04500000000002,"duration":3.2889999999999873,"text":"제가 조개구이 먹을 때 가장 중요한 게 화력이거든요?"},{"start":212.336,"duration":1.4679999999999893,"text":"조개가 진짜 빨리 익어야 하잖아요"},{"start":213.80599999999998,"duration":2.7050000000000125,"text":"솔직히 조개구이 배도 안 차는데!"},{"start":216.513,"duration":2.9399999999999977,"text":"이거 늦게 익으면 배고파서 답도 없단 말이에요!"},{"start":219.45499999999998,"duration":1.5600000000000023,"text":"감사합니다"},{"start":221.903,"duration":2.0829999999999984,"text":"밑반찬! 좋아 좋아"},{"start":223.988,"duration":1.5759999999999934,"text":"산낙지가 나오네?"},{"start":225.566,"duration":2.573999999999984,"text":"감사합니다"},{"start":228.6,"duration":3.2110000000000127,"text":"와 관자 진짜 두꺼워"},{"start":231.813,"duration":3.048000000000002,"text":"- 이거 관자 반으로 자른 거죠? - 네"},{"start":234.863,"duration":3.6709999999999923,"text":"반 자른 건데 두께가 이렇게 두껍다고? 보이세요?"},{"start":242.898,"duration":2.8100000000000023,"text":"살짝 뒤집어서 조금 더 굽다가"},{"start":245.95,"duration":4.923000000000002,"text":"열렸어, 방금 팍 열리는 거 봤어요?"},{"start":250.875,"duration":1.3739999999999952,"text":"근데 이거는 무슨 조개지?"},{"start":252.251,"duration":2.1899999999999977,"text":"저 조개구이집 가서 이런 조개를 본 적이 없어요!"},{"start":254.443,"duration":1.1029999999999802,"text":"피디님 본 적 있어요?"},{"start":255.548,"duration":1.413000000000011,"text":"저건 칼조개예요"},{"start":256.963,"duration":0.6809999999999832,"text":"칼조개!"},{"start":257.646,"duration":1.9079999999999586,"text":"칼조개요? 처음 보는데?"},{"start":259.555,"duration":2.2280000000000086,"text":"- 거의 안 나와요 - 그래요?"},{"start":261.785,"duration":1.3909999999999627,"text":"그래도 맛은 제일 나아요"},{"start":263.178,"duration":1.4250000000000114,"text":"맛은 제일 맛있어요?"},{"start":264.605,"duration":1.0439999999999827,"text":"너무 궁금하다!"},{"start":265.651,"duration":1.8209999999999695,"text":"대합을 먼저 먹어보겠습니다!"},{"start":267.474,"duration":1.204999999999984,"text":"관자랑 같이!"},{"start":273.241,"duration":1.8740000000000236,"text":"와! 조개구이 진짜 진해!"},{"start":275.117,"duration":1.686999999999955,"text":"그리고 연탄불에 구워서"},{"start":276.806,"duration":2.268000000000029,"text":"조개에 연탄 향이 쫙 배어서"},{"start":279.076,"duration":2.8239999999999554,"text":"불 향이 진짜 진하게 나요"},{"start":281.902,"duration":1.4730000000000132,"text":"이게 불이 세니까"},{"start":283.377,"duration":1.964999999999975,"text":"연탄 향이 더 잘 뱄다!"},{"start":286.472,"duration":2.9990000000000236,"text":"일단은 이 키조개를 먼저 잘라보겠습니다"},{"start":292.58299999999997,"duration":1.3010000000000446,"text":"사각사각 잘려"},{"start":295.28,"duration":2.3450000000000273,"text":"그리고 얘는 제가 통으로 먹을 거예요!"},{"start":297.627,"duration":7.947999999999979,"text":"키조개는 국물 아까우니까 조개구이 양념에 싹 부어"},{"start":306.771,"duration":2.204999999999984,"text":"이거 맛있는 거라고 했는데 다..."},{"start":308.978,"duration":2.3179999999999836,"text":"이렇게 하면 질겨지는데, 난 바보야"},{"start":311.298,"duration":3.384999999999991,"text":"아 근데 이 칼조개가 너무 아까운 게"},{"start":314.685,"duration":2.548999999999978,"text":"이게 맛있는 거라고 하셨는데"},{"start":317.236,"duration":2.0090000000000146,"text":"제가 다 태워먹었어요..."},{"start":319.247,"duration":0.9639999999999986,"text":"질겨졌겠지...?"},{"start":324.346,"duration":1.2919999999999732,"text":"지쨔 맛있다..."},{"start":325.64,"duration":0.8120000000000118,"text":"이게..."},{"start":326.454,"duration":2.134999999999991,"text":"원래 이 맛이면은..."},{"start":328.591,"duration":2.105000000000018,"text":"일부러 태워 먹을 정도로 맛있는데?..."},{"start":330.698,"duration":1.6710000000000491,"text":"진짜 하나도 안 질기고"},{"start":332.371,"duration":1.4890000000000327,"text":"엄청 쫄깃쫄깃하고"},{"start":333.862,"duration":1.9119999999999777,"text":"사각거리고 진짜 맛있어요..."},{"start":335.776,"duration":1.622000000000014,"text":"칼조개가 진짜 맛있네!"},{"start":337.903,"duration":4.3209999999999695,"text":"관자 반 자른 건데도 진짜 두껍죠?"},{"start":354.94,"duration":2.242999999999995,"text":"확실히 겨울에 조개가 맛있구나"},{"start":369.64,"duration":2.2250000000000227,"text":"조개에서 나오는 국물 있잖아요"},{"start":371.867,"duration":3.822999999999979,"text":"이게 깨끗하면 진짜 해감이 잘된 건데"},{"start":375.692,"duration":3.019999999999982,"text":"진짜 불순물 하나 없이 엄청 뽀얗게 나와요"},{"start":378.714,"duration":2.187999999999988,"text":"태워먹은 전복..."},{"start":380.904,"duration":1.4039999999999964,"text":"미안하다..."},{"start":382.31,"duration":1.8519999999999754,"text":"이 부분 있죠? 볼록, 까만 부분"},{"start":384.164,"duration":1.1210000000000377,"text":"다 자르지 말고"},{"start":397.105,"duration":1.7169999999999845,"text":"전복이 약간"},{"start":398.824,"duration":2.716000000000008,"text":"겉에만 타고 안에는 덜 익었는데"},{"start":401.54200000000003,"duration":2.44399999999996,"text":"사각사각 전복회 먹는 것처럼 맛있다!"},{"start":410.236,"duration":1,"text":"가리비"},{"start":411.862,"duration":2.7239999999999895,"text":"가리비 조그만 거 여러 개 올리고"},{"start":414.588,"duration":1.0179999999999723,"text":"더 올려"},{"start":418.488,"duration":0.7160000000000082,"text":"산낙지가 있어요"},{"start":419.206,"duration":2.1719999999999686,"text":"사실 제가 산낙지를 잘 못 먹어요"},{"start":421.38,"duration":1.8149999999999977,"text":"여기 들어가면 얘가 익지 않을까?"},{"start":423.197,"duration":2.483000000000004,"text":"미안하다, 좀 떨어져 줄래?"},{"start":425.682,"duration":0.9749999999999659,"text":"여기 이렇게 좀 넣어"},{"start":433.355,"duration":1.3739999999999668,"text":"이거 너무 좋아요"},{"start":434.731,"duration":1.3759999999999764,"text":"우와 낙지가 다 익었어"},{"start":436.109,"duration":1.3940000000000055,"text":"미안하다 낙지야ㅋㅎㅎ"},{"start":440.575,"duration":0.8410000000000082,"text":"이렇게 한번 드셔보세요!"},{"start":441.418,"duration":2.7169999999999845,"text":"조개 국물을 쫙 빨아들여서 짭짤하니 맛있어"},{"start":468.443,"duration":3.3629999999999995,"text":"키조개 너무 뜨거울 거 같아서 내장 먹기 전에 한 번 터트려 줄게요"},{"start":471.808,"duration":2.6170000000000186,"text":"이게 안에 이렇게 탁 터트리면 내장이"},{"start":485.476,"duration":1.274000000000001,"text":"진한 내장 맛"},{"start":491.844,"duration":1.3899999999999864,"text":"와 1등..."},{"start":493.236,"duration":1.5790000000000077,"text":"압도적인 1등 칼조개다"},{"start":502.954,"duration":1.134999999999991,"text":"안 질기네?"},{"start":504.687,"duration":3.0179999999999723,"text":"겨울이라서 조개가 진짜 맛있는 시기인가 봐요"},{"start":507.707,"duration":2.788000000000011,"text":"관자가 엄청 오래 익혔는데 안 질겨졌어요!"},{"start":515.386,"duration":3.0120000000000573,"text":"전복 위에 전복내장소스를 살짝 묻힌 다음에"},{"start":530.4159999999999,"duration":2.2690000000000055,"text":"이렇게 보도라운..."},{"start":532.686,"duration":2.034999999999968,"text":"전복 식감은..."},{"start":534.723,"duration":1.8150000000000546,"text":"살짝 거의 수비드 전복인데?!"},{"start":536.54,"duration":3.7549999999999955,"text":"암컷 조개가 좀 더 부들부들하고 야들야들"},{"start":540.296,"duration":3.133999999999901,"text":"수컷 조개가 사각사각 그런 식감이 있는데"},{"start":543.431,"duration":2.0529999999999973,"text":"방금 먹은 조개가 암컷 조개고"},{"start":545.486,"duration":1.9080000000000155,"text":"아까 먹은 게 수컷 조개인가 봐요"},{"start":559.521,"duration":0.6159999999999854,"text":"이렇게 약간"},{"start":560.138,"duration":2.9389999999999645,"text":"국물에 졸이듯이 구워야 맛있어요!"},{"start":563.079,"duration":1.6720000000000255,"text":"무조건 조개는 이렇게 익혀야 돼요"},{"start":565.454,"duration":2.0170000000000528,"text":"국물이 다 끓어오르잖아요"},{"start":567.473,"duration":2.1100000000000136,"text":"그때 한 번 얘가 톡 떨어지거든요?"},{"start":569.584,"duration":1.5020000000000664,"text":"뒤집어 줘요"},{"start":571.088,"duration":2.1440000000000055,"text":"얘도 이렇게 뒤집어 줍니다"},{"start":573.233,"duration":1.3280000000000882,"text":"살짝 졸여져서"},{"start":574.563,"duration":2.330000000000041,"text":"조개 국물이 노르스름해졌을 때 먹으면"},{"start":576.895,"duration":0.7690000000000055,"text":"제일 맛있어요!"},{"start":577.665,"duration":1.7980000000000018,"text":"저는 망했지만요"},{"start":596.326,"duration":2.558999999999969,"text":"얘는 계속 왜 반대로 될까? 뭐가 있나?"},{"start":598.887,"duration":1.5730000000000928,"text":"조개가 달궈지면"},{"start":600.462,"duration":0.5879999999999654,"text":"위에로 붙어요!"},{"start":601.051,"duration":1.02699999999993,"text":"아 위에로 붙어요?"},{"start":602.079,"duration":1.7410000000000991,"text":"어쩔 수가 없구나..."},{"start":603.822,"duration":1.7849999999999682,"text":"굴이 한 번씩 열어봐야 할 것 같긴 하다"},{"start":605.608,"duration":2.8320000000001073,"text":"이거 타면은 다 눌어붙잖아요..."},{"start":608.442,"duration":1.5460000000000491,"text":"걔는 석화가 아닌 것 같은데?"},{"start":609.99,"duration":0.7839999999999918,"text":"어머 이거 새우!!!"},{"start":610.776,"duration":0.9410000000000309,"text":"안 돼!!!"},{"start":611.718,"duration":2.5590000000000828,"text":"저는 이거 굴인 줄 알고"},{"start":614.279,"duration":2.058999999999969,"text":"어떡해, 새우였어"},{"start":616.34,"duration":0.6359999999999673,"text":"이게 그치..."},{"start":616.978,"duration":1.2420000000000755,"text":"저게 굴일 리가 없지..."},{"start":618.222,"duration":2.147000000000048,"text":"이 굴을 다시 익히겠습니다..."},{"start":620.371,"duration":2.3730000000000473,"text":"얘 다... 굴에 신경 쓰느라"},{"start":628.7860000000001,"duration":0.8029999999998836,"text":"진짜 오늘 왜 이래"},{"start":629.591,"duration":1.5599999999999454,"text":"이거 맛있는 조갠데..."},{"start":664.208,"duration":2.3050000000000637,"text":"여기 끝에를 살살살"},{"start":674.498,"duration":1.7059999999999036,"text":"와 방금 전복 진짜 맛있었어!"},{"start":676.205,"duration":1.4489999999999554,"text":"새우가 너무 타서"},{"start":677.656,"duration":2.8780000000000427,"text":"새우는 다시 예쁘게, 맛있게 굽겠습니다"},{"start":681.544,"duration":2.0750000000000455,"text":"그래, 나왔으니 구워져라"},{"start":691.124,"duration":2.4739999999999327,"text":"여기 조개가 진짜 너무 맛있어요!"},{"start":695.6610000000001,"duration":3.0039999999999054,"text":"- 지금 다 먹어도 되는 거죠? - 네, 석화는 드셔도 됩니다"},{"start":698.6659