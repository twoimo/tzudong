9773,"text":"순대 크기가"},{"start":683.25,"duration":1.2000000000000455,"text":"크기도 이만하고"},{"start":685.26,"duration":1.8700000000000045,"text":"보이세요?"},{"start":687.132,"duration":1.0680000000000973,"text":"진짜 큽니다ㄷㄷ"},{"start":703.35,"duration":3.2999999999999545,"text":"일반 순대... 같지가 않은데? 전혀?"},{"start":706.651,"duration":4.439000000000078,"text":"약간 콩나물, 숙주 들어간 국밥 맛도 나요"},{"start":711.59,"duration":1.2999999999999545,"text":"안에 뭔가..."},{"start":712.891,"duration":2.3390000000000555,"text":"당면이랑 그런 쫀득함만 느껴지는"},{"start":715.232,"duration":2.0579999999999927,"text":"쫜득쫜득한 순대가 아니라"},{"start":717.2909999999999,"duration":5.9090000000001055,"text":"촉촉하고 채소 식감도 많이 느껴지고"},{"start":723.202,"duration":1.4980000000000473,"text":"되게 독특하네?"},{"start":754.44,"duration":4,"text":"접시가 작아서 금방 먹을 줄 알았는데"},{"start":758.442,"duration":3.467999999999961,"text":"곱창이 아무래도 턱으로 많이 씹다 보니까"},{"start":761.9110000000001,"duration":3.603999999999928,"text":"턱이 아파서 좀 천천히 먹었거든요?"},{"start":765.516,"duration":3.83400000000006,"text":"아까 6시 이후부터 웨이팅이 지금까지 계속 있어요"},{"start":769.352,"duration":3.4980000000000473,"text":"그래서 생각보다 제가 너무 오래 먹은 것 같아서"},{"start":772.852,"duration":2.868000000000052,"text":"제가 급하게 먹고 나가는 게 좀 그렇다라고"},{"start":775.722,"duration":1.9980000000000473,"text":"하시는 분들이 댓글에 좀 계셔서"},{"start":777.722,"duration":1.59800000000007,"text":"최대한 안 하려고 그랬는데"},{"start":779.322,"duration":3.368000000000052,"text":"제가 조금 너무 오래 있으면 민폐 드릴 것 같아서"},{"start":782.692,"duration":2.8079999999999927,"text":"물론 제가 매운 걸 먹기 싫어서 그런 건 아니고요"},{"start":785.502,"duration":1.7980000000000018,"text":"아니요, 사실 매운 거 못 먹겠어요"},{"start":788,"duration":5.0499999999999545,"text":"이거 포장해서 마요네즈 1통 사서"},{"start":793.051,"duration":2.88900000000001,"text":"거기다 푹 적셔서 먹어야 될 것 같아요"},{"start":833.752,"duration":1.2280000000000655,"text":"제가"},{"start":834.982,"duration":2.197999999999979,"text":"진짜 오늘 사실..."},{"start":837.181,"duration":1.4689999999999372,"text":"오랜만에...!"},{"start":838.651,"duration":1.6990000000000691,"text":"진짜 몇 달 만에"},{"start":840.352,"duration":1.4980000000000473,"text":"컨디션이 좀 안 좋은 날이었거든요?"},{"start":841.852,"duration":1.2380000000000564,"text":"딱히 어디가 아픈 건 아닌데"},{"start":843.092,"duration":2.072999999999979,"text":"있잖아요, 컨디션 진짜 안 좋은 날"},{"start":845.166,"duration":2.533999999999992,"text":") 근데 하필 오늘 운이 안 좋게"},{"start":847.702,"duration":1.3980000000000246,"text":"컨디션이 안 좋아서"},{"start":849.102,"duration":0.9980000000000473,"text":"뭔가"},{"start":850.102,"duration":2.52800000000002,"text":"아침에도 그렇고 지금도 그렇고 제대로 못 먹었는데"},{"start":852.632,"duration":3.5680000000000973,"text":"제가 오늘 너무 아쉽게 컨디션이 안 좋아서"},{"start":856.202,"duration":1.947999999999979,"text":"잘 못 먹은 거 같아서 조금 아쉽네요"},{"start":858.705,"duration":3.2350000000000136,"text":"70년 전통 곱창이라고 해서"},{"start":861.942,"duration":2.1680000000000064,"text":"'어떤 맛일까?' 하고 먹어봤는데"},{"start":864.112,"duration":1.52800000000002,"text":"먹어본 적 없는"},{"start":865.641,"duration":3.6689999999999827,"text":"정말 특별하면서도 맛있는 곱창이었어서"},{"start":869.311,"duration":1.9389999999999645,"text":"정말 맛있게 먹었습니다"},{"start":871.252,"duration":3.59800000000007,"text":"분위기도 술 마시기 너무 좋아서"},{"start":874.852,"duration":2.048000000000002,"text":"간단하게 술 한잔하면서"},{"start":876.901,"duration":2.2590000000000146,"text":"안주로 먹기 굉장히 좋은 음식인 것 같아요"},{"start":879.1610000000001,"duration":1.2289999999999281,"text":"애주가분들은"},{"start":880.391,"duration":2.969000000000051,"text":"한번 들러보셔도 좋을 집이라고 생각합니다!"},{"start":883.362,"duration":2.9980000000000473,"text":"오늘도 잘 먹었습니다~!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
