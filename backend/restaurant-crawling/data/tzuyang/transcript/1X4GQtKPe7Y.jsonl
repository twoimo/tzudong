{"youtube_link":"https://www.youtube.com/watch?v=1X4GQtKPe7Y","channel_name":"tzuyang","language":"ko","collected_at":"2026-02-27T04:53:31.152+09:00","transcript":[{"start":5.601,"duration":3.079999999999999,"text":"너무 맛있겠다, 감사합니다"},{"start":8.681,"duration":2.915000000000001,"text":"원래 뭐가 이렇게 많이 나와요?"},{"start":17.598,"duration":2.2330000000000005,"text":"거의 1등인데? 어떻게 이렇게 맛있지?"},{"start":19.833,"duration":1.2900000000000027,"text":"진짜 수준급 게장이다"},{"start":21.125,"duration":2.053000000000001,"text":"게장은 태안이었구먼"},{"start":41.521,"duration":1.8440000000000012,"text":"안녕하세요 여러분"},{"start":43.367,"duration":2.815000000000005,"text":"제가 오늘은 지금 서산에 왔는데"},{"start":46.184,"duration":2.128,"text":"서산 오면 항상 먹는 게 있거든요?"},{"start":48.314,"duration":3.2209999999999965,"text":"오늘 게장을 먹으러 왔습니다"},{"start":51.537,"duration":3.198999999999998,"text":"서해 자체가 게가 많이 나고 게가 유명한데"},{"start":54.738,"duration":1.7449999999999974,"text":"서산..."},{"start":56.485,"duration":1.1679999999999993,"text":"태안..."},{"start":57.655,"duration":1.7289999999999992,"text":"아 여기 태안이지"},{"start":59.386,"duration":2.0279999999999987,"text":"죄송해요, 태안이에요..."},{"start":61.416,"duration":3.7950000000000017,"text":"서산이랑 태안 두 곳 게장이 정말 유명하거든요"},{"start":65.212,"duration":1.948999999999998,"text":"게장집도 많고 유명한 데도 많은데"},{"start":67.163,"duration":2.2250000000000085,"text":"'와 진짜 이렇게 많이 오신다고?' 할 정도로"},{"start":69.39,"duration":1.8829999999999956,"text":"사진 보니까 깜짝 놀랐거든요"},{"start":71.274,"duration":1.9879999999999995,"text":"또 그만큼 너무 맛있다고 해서"},{"start":73.264,"duration":0.8800000000000097,"text":"그래서 제가 오늘"},{"start":74.146,"duration":1.7620000000000005,"text":"평일 오픈런으로 왔습니다"},{"start":75.908,"duration":3.0760000000000076,"text":"이미 오픈런 하시는 분들이 되게 많으시더라고요"},{"start":78.985,"duration":1.3200000000000074,"text":"진짜 맛집인 거죠!"},{"start":80.307,"duration":2.8319999999999936,"text":"게장 말고도 게국지 같은 찌개도 있는데"},{"start":83.14,"duration":1.9129999999999967,"text":"너무 맛있어 보이더라고요"},{"start":85.054,"duration":1.277000000000001,"text":"그거 먹고 싶어요"},{"start":89.916,"duration":5.052999999999997,"text":"안녕하세요, 반찬이 이렇게 바로 나와요"},{"start":94.97,"duration":2.4000000000000057,"text":"김에다가 명란이랑 달래 해서"},{"start":97.372,"duration":3.207000000000008,"text":"밥 싸서 조금 드시면 정말 맛있어요"},{"start":100.58,"duration":2.847999999999999,"text":"8만 5,000원짜리 시키면 어떻게 나와요?"},{"start":103.429,"duration":1.899000000000001,"text":"저거는 저희가 포장 판매!"},{"start":105.33,"duration":1.6950000000000074,"text":"- 아 포장 판매요? - 네네!"},{"start":107.027,"duration":2.2010000000000076,"text":"게장백반으로 주문을 하시면..."},{"start":109.229,"duration":1.9909999999999997,"text":"게국지가 서비스로 같이 나와요"},{"start":111.22200000000001,"duration":2.1979999999999933,"text":"게국지랑 꽃게장이랑 같이 나오는데"},{"start":113.422,"duration":1.6210000000000093,"text":"게장백반 주문하시고 부족하면"},{"start":115.045,"duration":2.7369999999999948,"text":"곁들임 메뉴로 추가를 해서 드시면 돼요!"},{"start":117.783,"duration":1.7609999999999957,"text":"게장 1마리에 보통 3만 원 넘어가는 데가"},{"start":119.545,"duration":1.421999999999997,"text":"사실 대부분이잖아요"},{"start":120.969,"duration":3.1260000000000048,"text":"게장이 2만 5,000원으로 1마리 추가할 수 있고"},{"start":124.097,"duration":2.450000000000003,"text":"양념게장은 2만 원으로 1마리 추가할 수 있으니까"},{"start":126.548,"duration":1.3049999999999926,"text":"되게 괜찮네!"},{"start":127.854,"duration":0.9059999999999917,"text":"그러면"},{"start":128.762,"duration":3.899000000000001,"text":"간장게장 10마리랑 양념게장 5마리 이렇게!"},{"start":132.663,"duration":1.313999999999993,"text":"부탁드립니다, 감사합니다!"},{"start":133.97899999999998,"duration":1.3690000000000282,"text":"일단 이거 3종이라는데"},{"start":135.35,"duration":2.9639999999999986,"text":"여기 김에다가 밥 싸서"},{"start":138.316,"duration":3.4110000000000014,"text":"달래장을 같이 먹으면 진짜 맛있대요"},{"start":148.275,"duration":2.0589999999999975,"text":"이 정도면 진짜 제대로 된 백반집인데?"},{"start":150.336,"duration":1.3199999999999932,"text":"너무 맛있다"},{"start":151.65800000000002,"duration":1.8209999999999695,"text":"반찬도 딱 봐도 맛있겠다"},{"start":155.498,"duration":1.3230000000000075,"text":"맛있네ㅎ"},{"start":160.235,"duration":5.2309999999999945,"text":"원래 뭐가 이렇게 많이 나와요?"},{"start":165.46800000000002,"duration":2.914999999999992,"text":"3, 4인 시키면 이렇게 나와요?"},{"start":168.385,"duration":1.4180000000000064,"text":"진짜 잘 나온다..."},{"start":169.805,"duration":2.6049999999999898,"text":"진짜 이거 어디 가면 돈 엄청 받을 것 같은데"},{"start":172.412,"duration":2.2419999999999902,"text":"이거 한 3만 원 이상 받을 것 같은데"},{"start":174.656,"duration":2.7319999999999993,"text":"게장집 중에서 진짜 역대급 가성비인데?"},{"start":181.53,"duration":1.8389999999999986,"text":"내가 좋아하는 맛이야"},{"start":183.371,"duration":1.7630000000000052,"text":"꽃게된장찌개 맛인데"},{"start":185.136,"duration":1.5550000000000068,"text":"진짜 진하고 맛있어"},{"start":187.651,"duration":1.9819999999999993,"text":"아니 이거는 게국지를 시키시면"},{"start":189.635,"duration":4.175000000000011,"text":"돌게가 서비스로 나와요"},{"start":193.812,"duration":2.2789999999999964,"text":"저 돌게도 저렇게 서비스로 많이 나오고"},{"start":196.093,"duration":1.7790000000000248,"text":"요즘 게가 얼마나 비싼데..."},{"start":197.874,"duration":2.38900000000001,"text":"몇 마리씩... 2마리?"},{"start":200.265,"duration":3.5410000000000252,"text":"엄청 많이 들어갔어, 3마리?"},{"start":204.323,"duration":1.7789999999999964,"text":"우와 대박..."},{"start":206.946,"duration":3.960000000000008,"text":"너무 맛있겠다, 감사합니다"},{"start":210.90800000000002,"duration":1.093999999999994,"text":"예쁘다"},{"start":220.626,"duration":3.6629999999999825,"text":"10마리, 6마리, 지금 총 16마리거든요?"},{"start":224.291,"duration":2.1410000000000196,"text":"원래 한 20마리 먹거든요, 오늘 근데"},{"start":226.434,"duration":2.8669999999999902,"text":"게국지도 먹고 이것저것 또 먹고 싶어서"},{"start":229.303,"duration":1.6839999999999975,"text":"간단하게 시켰습니다"},{"start":231.40800000000002,"duration":1.4699999999999704,"text":"잘 먹겠습니다~!"},{"start":232.88,"duration":1.6069999999999993,"text":"너무 기대돼요, 어떡해"},{"start":234.489,"duration":2.181999999999988,"text":"우와 이거 한번 보실래요?"},{"start":256.189,"duration":3.5569999999999595,"text":"밥을 안 먹어도 될 정도로 짠맛이 없고"},{"start":259.748,"duration":2.8220000000000027,"text":"비린내도 진짜 하나도 안 나고"},{"start":262.572,"duration":1.9399999999999977,"text":"어떻게 이렇게 맛있지?"},{"start":273.873,"duration":1.2379999999999995,"text":"어떻게 이렇게 맛있지?22"},{"start":275.113,"duration":2.4630000000000223,"text":"다리 살도 완전 꽉 차있을 것 같아"},{"start":283.817,"duration":2.1709999999999923,"text":"일단 좋은 게예요, 뼈도 단단하고"},{"start":285.99,"duration":2.5679999999999836,"text":"다리는 약간 짭짤한데 몸통은"},{"start":288.56,"duration":1.795000000000016,"text":"거의 밥이 없어도 될 정도로..."},{"start":290.35699999999997,"duration":1.2580000000000382,"text":"밥이 없어도 될 정도로..."},{"start":291.617,"duration":1.6370000000000005,"text":"밥이 없어도 될 정도로 따듯하..."},{"start":293.256,"duration":1.9210000000000491,"text":"밥이 없어도 될 정도로"},{"start":295.179,"duration":1.5769999999999982,"text":"그... 뭐냐..."},{"start":296.758,"duration":2.247000000000014,"text":"안 짜고!"},{"start":299.007,"duration":3.6610000000000014,"text":"야들야들하게 식감이 살아있는 살이에요"},{"start":302.67,"duration":1.5989999999999895,"text":"게가 진짜 신선한 거예요"},{"start":304.271,"duration":1.5039999999999623,"text":"요거 버리시면 안 돼요"},{"start":305.777,"duration":2.069000000000017,"text":"이렇게 벌리면..."},{"start":316.868,"duration":1.5570000000000164,"text":"이거 살 살아있는 거 보이세요?"},{"start":318.427,"duration":1.308999999999969,"text":"탱글탱글하게?"},{"start":325.069,"duration":1,"text":"이 살을"},{"start":332.148,"duration":1.8619999999999663,"text":"여기 게장 진짜 수준급 게장이다"},{"start":334.012,"duration":1.8770000000000095,"text":"제가 게장 많이 먹어봤잖아요?"},{"start":335.891,"duration":4.114999999999952,"text":"간장 양념도 거슬리는 거 하나 없이"},{"start":340.008,"duration":2.6890000000000214,"text":"딱 게를 보완해 주는 정도의 간장 맛?"},{"start":364.223,"duration":2.620999999999981,"text":"솔직히 여기 다리 자르기 귀찮잖아요"},{"start":368.237,"duration":3.5439999999999827,"text":"누르면 다리 살이 이렇게 나와요"},{"start":376.327,"duration":2.562000000000012,"text":"이제 양념게장 먹어보겠습니다"},{"start":383.273,"duration":1.1679999999999495,"text":"이건 맛없을 수 없어"},{"start":395.686,"duration":2.886000000000024,"text":"맛있다 맛있다 맛있다"},{"start":401.254,"duration":2.0860000000000127,"text":"양념게장은 꽤 맵거든요?"},{"start":403.342,"duration":1.6190000000000282,"text":"꽤 매운데..."},{"start":407.407,"duration":1.4320000000000164,"text":"살이 너무 달아"},{"start":423.283,"duration":1.766999999999996,"text":"양념이 진짜 많이 매워요"},{"start":425.052,"duration":1.3589999999999804,"text":"마늘 매운맛이에요!"},{"start":426.413,"duration":2.4069999999999823,"text":"아 근데 밥이랑 먹으면 너무 맛있겠다!"},{"start":454.929,"duration":7.613000000000056,"text":"이게 게가 지금 살이 다 풀어져서"},{"start":467.956,"duration":3.9209999999999923,"text":"이래서 여기 와서 간장게장 먹는구나"},{"start":471.879,"duration":1.2629999999999768,"text":"진짜 맛있다"},{"start":478.69100000000003,"duration":1.3769999999999527,"text":"진짜요?"},{"start":480.07,"duration":2.275000000000034,"text":"- 꽃게탕은 이거보다 더 맛있어요?! - 네"},{"start":482.347,"duration":1.343999999999994,"text":"근데 이게 된장이 안 들어갔어요?"},{"start":483.693,"duration":0.8830000000000382,"text":"된장이 안 들어갔어요"},{"start":484.578,"duration":0.7060000000000173,"text":"간장 베이스예요!"},{"start":485.286,"duration":3.252999999999986,"text":"저 이거 조금 억울해서 말씀드리고 싶었어요"},{"start":488.541,"duration":1.9300000000000068,"text":"근데 어떻게 된장 맛이 나지...?"},{"start":490.473,"duration":1.5179999999999723,"text":"간장 베이스예요"},{"start":493.986,"duration":3.163000000000011,"text":"진짜 게장집 중에 가장 좋아하는 집이 될 거 같아요"},{"start":497.151,"duration":2.1990000000000123,"text":"- 진짜요? 영광이에요 - 너무 맛있어요"},{"start":499.351,"duration":1.16700000000003,"text":"여기 안에 있는 게도"},{"start":500.52,"duration":0.9710000000000036,"text":"왜 이렇게 좋은 게가 들어가요?"},{"start":501.493,"duration":1.7830000000000155,"text":"- 이게 게장 게를 넣은 건가요? - 맞아요!"},{"start":503.278,"duration":2.252999999999986,"text":"거뭇거뭇한 거는 간장에 좀 오래 있던 게!"},{"start":505.533,"duration":1.3209999999999695,"text":"- 간장에 오래돼 있던 거? - 네"},{"start":514.115,"duration":0.8460000000000036,"text":"저 꽃게탕 먹으면서"},{"start":514.962,"duration":2.007000000000062,"text":"이렇게 살이 꽉 찬 건 처음인 것 같아요"},{"start":516.971,"duration":1.9610000000000127,"text":"꽃게백숙 같은 맛이 나요"},{"start":518.933,"duration":2.4880000000000564,"text":"오히려 꽃게백숙보다 촉촉해서 더 맛있어"},{"start":521.423,"duration":4.716000000000008,"text":"여기다가 살짝 밥을 말아야겠어요"},{"start":531.913,"duration":0.7930000000000064,"text":"여기 김에다!"},{"start":562.344,"duration":1.7369999999999663,"text":"명란 올려, 짜려나?"},{"start":569.517,"duration":0.8409999999998945,"text":"와 이거 진짜 별미다"},{"start":570.359,"duration":1.7509999999999764,"text":"오와 맛있다!"},{"start":576.721,"duration":2.350999999999999,"text":"양념게장에다 명란도 짱 맛있겠는데?"},{"start":594.657,"duration":0.9769999999999754,"text":"끝내주는데?"},{"start":595.636,"duration":1.650000000000091,"text":") 게살 바르기의 달인이거든요?"},{"start":597.287,"duration":2.120999999999981,"text":"어떻게 바르는지 보여드리겠습니다"},{"start":599.41,"duration":3.1230000000000473,"text":"1. 쭉 짜주고 게장을 그냥 부숴버린 다음에"},{"start":602.535,"duration":4.288999999999987,"text":"2. 껍질 사이사이로 긁어내면 이렇게 아주 깔끔하게"},{"start":606.825,"duration":3.475999999999999,"text":"꾹꾹"},{"start":610.303,"duration":2.548999999999978,"text":"누르면 이렇게 다리 살도 나오는데"},{"start":612.853,"duration":2.9750000000000227,"text":"이렇게 하면 진짜 최대한 많이 먹을 수 있어요"},{"start":622.955,"duration":1.6849999999999454,"text":"얘는 뭔가 섞기 아까우니까"},{"start":624.641,"duration":1.1130000000000564,"text":"바로 먹겠습니다"},{"start":630.585,"duration":2.478999999999928,"text":"맛있어 보이는 건 확실히 맛있구나"},{"start":645.4,"duration":2.257000000000062,"text":"어떻게 이렇게 하나도 안 짜지?"},{"start":647.659,"duration":1.6789999999999736,"text":"살이 너무 달아!"},{"start":649.3389999999999,"duration":6.023000000000025,"text":"둘러서"},{"start":668.819,"duration":1.2000000000000455,"text":"어떻게 이래요?"},{"start":670.929,"duration":1.3079999999999927,"text":"이번엔 내장이다!"},{"start":672.238,"duration":3.0579999999999927,"text":"어쩐지 '왜 이렇게 알이 많지' 했더니"},{"start":675.298,"duration":1.6829999999999927,"text":"여기 다 긁어주세요!"},{"start":676.983,"duration":3.9340000000000828,"text":"모르시는 분이 꽤 계세요, 그래서 다 발라주시나 봐요"},{"start":680.919,"duration":1.2520000000000664,"text":"너무 센스가..."},{"start":682.569,"duration":1.1399999999999864,"text":"여기다 밥을"},{"start":684.4,"duration":1.2240000000000464,"text":"참기름 둘러서"},{"start":685.626,"duration":2.1480000000000246,"text":"원래 노른자 하나 탁 깨 넣어 먹어야 하는데"},{"start":703.636,"duration":1.8870000000000573,"text":"아 안녕하세요 사장님!"},{"start":705.525,"duration":1.1259999999999764,"text":"너무 맛있어요ㅎㅎ"},{"start":706.652,"duration":3.1499999999999773,"text":"진짜요? 감사합니다"},{"start":709.804,"duration":2.51400000000001,"text":"맛있게 천천히 드셔요"},{"start":712.319,"duration":1.6600000000000819,"text":"사장님 여기 몇 년 됐어요?"},{"start":713.981,"duration":2.1900000000000546,"text":"지금 26년째 돌아와요!"},{"start":716.173,"duration":1.2670000000000528,"text":"오래됐구나"},{"start":717.442,"duration":4.197000000000003,"text":"음식 해서 여러 분들이랑 나눠 먹기 좋아해서"},{"start":721.641,"duration":2.8870000000000573,"text":"그냥 그렇게 지었어요"},{"start":724.53,"duration":0.9360000000000355,"text":"잘 먹을게요!"},{"start":725.468,"duration":2.062000000000012,"text":"- 네, 맛있게 드세요! - 감사합니다"},{"start":727.531,"duration":1.9910000000000991,"text":"양념게장 이번에 싹 발라볼게요"},{"start":734.405,"duration":2.883000000000038,"text":"- 드시고 싶으시다고 - 정말요?"},{"start":737.29,"duration":1.8899999999999864,"text":"맛있게 잘 드셔서ㅎ"},{"start":739.181,"duration":1.8079999999999927,"text":"사장님 게장 많이 드시지 않으세요?"},{"start":740.991,"duration":1.0190000000000055,"text":"저희요? 네ㅎ"},{"start":742.012,"duration":1.4220000000000255,"text":"매번은 아니구"},{"start":743.435,"duration":2.562000000000012,"text":"- 자주? - 땡길 때!"},{"start":745.998,"duration":1.6649999999999636,"text":"혹시 게국지도 택배 돼요?"},{"start":747.665,"duration":3.399000000000001,"text":"- 날이 추울 때 배송 가능해요 - 상하니까?"},{"start":751.064,"duration":1.0740000000000691,"text":"네, 맞아요"},{"start":768.581,"duration":2.380999999999972,"text":"달래장까지 해서"},{"start":770.9639999999999,"duration":1.740000000000009,"text":"이렇게 먹는 거였어"},{"start":772.706,"duration":1.3110000000000355,"text":"이게 정답이었어"},{"start":789.856,"duration":2.02800000000002,"text":"게가 훨씬 달게 느껴진다"},{"start":791.886,"duration":2.7490000000000236,"text":"단맛이 엄청 극대화되는데?"},{"start":804.843,"duration":1.1650000000000773,"text":"끝내준다..."},{"start":806.01,"duration":1.9650000000000318,"text":"2월까지 매일 배달시켜 먹고 싶다"},{"start":807.975,"duration":1.947999999999979,"text":"제가 꽃게탕 진짜 좋아하거든요"},{"start":818.224,"duration":1.9459999999999127,"text":"너무 맛있어, 어뜩행..."},{"start":820.171,"duration":1.2929999999998927,"text":"게가 진짜 안 짜서"},{"start":821.466,"duration":2.134999999999991,"text":"공깃밥 지금 하나밖에 안 먹었어"},{"start":823.603,"duration":1.9940000000000282,"text":"내가 봤을 때 얘는 밥도둑이 아니라..."},{"start":825.598,"duration":1.7240000000000464,"text":"그냥 도둑이에요"},{"start":827.324,"duration":1.990000000000009,"text":"근데 원래 육수 리필해 주세요?"},{"start":829.315,"duration":1.4939999999999145,"text":"네, 원래 해드려요"},{"start":830.81,"duration":1.125,"text":"진짜 역대급이다..."},{"start":831.936,"duration":3.562000000000012,"text":"너무 좋다, 육수가 무제한이야"},{"start":835.699,"duration":1.9710000000000036,"text":"게를 넌지고"},{"start":837.671,"duration":1.8149999999999409,"text":"솔직히 좀 아깝긴 하거든요?"},{"start":839.488,"duration":2.09699999999998,"text":"근데 솔직히 넣으면 더 맛있긴 해요"},{"start":848.186,"duration":1.8289999999999509,"text":"이게 똠얌꿍 같은 맛이 나요?"},{"start":851.163,"duration":1.02800000000002,"text":"좀 더 삭히면?"},{"start":852.193,"duration":5.489000000000033,"text":"게들 열심히 털어주고...)"},{"start":859.332,"duration":1.4519999999999982,"text":"이거 진짜 맛있겠다"},{"start":860.7860000000001,"duration":1.87399999999991,"text":"머리 다 이렇게 먹어야지"},{"start":865.929,"duration":2.8350000000000364,"text":"이게 진짜... 이게 진짜 맛있는데!"},{"start":883.772,"duration":1.9009999999999536,"text":"와 너무 맛있어, 어떡해..."},{"start":889.869,"duration":2.7679999999999154,"text":"아까 맛에서 간장 맛이 좀 더 진해지긴 했는데"},{"start":892.638,"duration":2.0860000000000127,"text":"맛있다, 애초에 베이스가 얘니까"},{"start":894.726,"duration":2.3079999999999927,"text":"맛이 크게 달라지진 않고"},{"start":903.474,"duration":1.961999999999989,"text":"어디서 게장 시킨다고 이걸 줘요"},{"start":906.228,"duration":1.4910000000000991,"text":"만족도가 너무 높다"},{"start":907.721,"duration":2.2029999999999745,"text":"밥을 먹을 시간이 됐어"},{"start":921.149,"duration":1.6689999999999827,"text":"노른자를..."},{"start":929.79,"duration":1.0070000000000618,"text":"톡"},{"start":937.329,"duration":5.280000000000086,"text":"명란까지 탁"},{"start":942.611,"duration":1.6200000000000045,"text":"한 입에 몇천 원이야"},{"start":956.642,"duration":2.450999999999908,"text":"게장이 너무 안 짜니까"},{"start":959.094,"duration":1.794999999999959,"text":"간장을 한 바퀴 둘러도 될 것 같아요"},{"start":960.891,"duration":4.946000000000026,"text":"김을 또 싸서 먹으면 기가 막힐 것 같은데"},{"start":974.868,"duration":1.7849999999999682,"text":"이쪽에서 까줄까?"},{"start":976.655,"duration":1.1560000000000628,"text":"이거요?"},{"start":977.813,"duration":2.592999999999961,"text":"감사합니당ㅎ"},{"start":980.407,"duration":1,"text":"달래장"},{"start":1003.526,"duration":2.657000000000039,"text":"감사합니다, 와 잘 발랐네"},{"start":1018.434,"duration":2.3530000000000655,"text":"다음 비빔밥은 양념게장!"},{"start":1020.789,"duration":8.214999999999918,"text":"이거 진짜 맛있겠다"},{"start":1038.659,"duration":2.7489999999997963,"text":"명란을 어떻게 같이 주실 생각을..."},{"start":1049.549,"duration":2.3430000000000746,"text":"참기름 필수, 명란 필수"},{"start":1063.225,"duration":2.1110000000001037,"text":"엄청 진해!"},{"start":1071.918,"duration":1.5230000000001382,"text":"맛있당..."},{"start":1073.443,"duration":1.433999999999969,"text":"2개는 말아서"},{"start":1074.879,"duration":2.400000000000091,"text":"국물이랑 같이 떠먹고..."},{"start":1080.459,"duration":2.7899999999999636,"text":"이거 국물 진짜 완전 엑기스예요"},{"start":1099.55,"duration":2.7050000000001546,"text":"엑기스 이거 버리기 아까운데"},{"start":1102.257,"duration":2.43100000000004,"text":"정말 맛있는 게장 되게 많이 먹어봤는데"},{"start":1104.69,"duration":1.3360000000000127,"text":"가격대도 그렇고"},{"start":1106.028,"duration":3.293999999999869,"text":"제대로 된 게국지가 나오는 것도 그렇고"},{"start":1109.323,"duration":2.9859999999998763,"text":"사장님과 직원분들이 너무 친절하시고"},{"start":1112.311,"duration":3.0900000000001455,"text":"굉장히 엄청나게 만족스러운"},{"start":1115.403,"duration":1.3430000000000746,"text":"그런 식당이었습니다"},{"start":1116.748,"duration":2.2719999999999345,"text":"서산에..."},{"start":1119.022,"duration":3.925000000000182,"text":"아 서산이래, 확실히 서해안 게장이 맛있네요"},{"start":1122.9470000000001,"duration":3.1109999999998763,"text":"직원들도 포장하고 저도 포장했어요"},{"start":1126.06,"duration":1.038000000000011,"text":"오늘도"},{"start":1127.1,"duration":2.122000000000071,"text":"잘 먹었습니다~!"},{"start":1129.224,"duration":1.1790000000000873,"text":"어우 맛있었어요?"},{"start":1130.405,"duration":1.8020000000001346,"text":"- 진짜 맛있었어요 - 다 끝나셨어요?"},{"start":1132.209,"duration":1.2699999999999818,"text":"사진 찍어쥬-!"},{"start":1133.481,"duration":1.3099999999999454,"text":"사인해 쥬-!!!"},{"start":1134.793,"duration":3.0920000000000982,"text":"게장 제일 많이 드셨어요"},{"start":1137.887,"duration":1.9420000000000073,"text":"이거랑 꽃게탕이랑 같이"},{"start":1139.831,"duration":2.6800000000000637,"text":"라면 사리 넣고 제조 한번 해보세요"},{"start":1145.228,"duration":1.5399999999999636,"text":"- 진짜 맛있겠다 - 이걸 어떻게 버려요"},{"start":1146.77,"duration":4.014000000000124,"text":"- 지나가시다 생각나면 들러주세요! - 아우 그럼요!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
