{"youtube_link":"https://www.youtube.com/watch?v=GQyNACahbyM","channel_name":"tzuyang","language":"ko","collected_at":"2026-02-27T04:53:49.012+09:00","transcript":[{"start":0.002,"duration":2.298,"text":"냉면 또 먹어"},{"start":2.301,"duration":1.399,"text":"알아요, 더 먹을 수 있어요"},{"start":12.892,"duration":1.088000000000001,"text":"먹보 이모"},{"start":13.982,"duration":1.6180000000000003,"text":"먹보 이모래요ㅋㅋ"},{"start":23.002,"duration":1.8480000000000025,"text":"또 하나만 더 먹으려고요"},{"start":29.114,"duration":0.7859999999999978,"text":"사장님"},{"start":29.901,"duration":1.1980000000000004,"text":"하나 뭘 또 먹어"},{"start":31.55,"duration":1.5999999999999979,"text":"안 돼~!"},{"start":45.932,"duration":2.0079999999999956,"text":"안녕하세요, 여러분!"},{"start":47.942,"duration":3.567999999999998,"text":"제가 오늘은 새해맞이로 떡국 먹으러 왔어요"},{"start":51.512,"duration":3.067999999999998,"text":"드디어 30살이 됐습니다"},{"start":54.582,"duration":1.6580000000000013,"text":"작년에도 제가 엄청 맛있는"},{"start":56.242,"duration":1.5080000000000027,"text":"설렁탕집에서 떡국 먹었는데"},{"start":57.752,"duration":1.8279999999999959,"text":"아 거기 설렁탕 또 먹고 싶다"},{"start":59.582,"duration":1.2980000000000018,"text":"진짜 맛있었는데"},{"start":60.882,"duration":2.9380000000000024,"text":"여기는 청량리인데 경동시장 근처에 있는"},{"start":63.822,"duration":1.7980000000000018,"text":"시장 골목 같은 곳이거든요"},{"start":65.622,"duration":2.5379999999999967,"text":"여기가 사실 원래 냉면집이에요"},{"start":68.161,"duration":2.0289999999999964,"text":"겨울에는 떡만둣국"},{"start":70.19200000000001,"duration":2.637999999999991,"text":"떡국 먹다가 냉면 당기면 먹어도 되는 거 아닌가?"},{"start":72.832,"duration":1.7280000000000086,"text":"매운 냉면집인데"},{"start":80.741,"duration":1.2590000000000003,"text":"안녕하세요"},{"start":82.002,"duration":3.0379999999999967,"text":"- 어떻게 이렇게 유명하신 분이 여기까지 오셨어요? - 어?! 저 아세요?"},{"start":85.042,"duration":2.7379999999999995,"text":"쯔양 모르는 사람이 어딨어요, 쯔양을"},{"start":87.782,"duration":1.4980000000000047,"text":"안녕하세요"},{"start":89.282,"duration":1.347999999999999,"text":"왜 여기까지 오셨어요, 쯔양 님"},{"start":90.631,"duration":2.0080000000000098,"text":"아 저 떡국 먹으러 왔어요ㅎㅎ"},{"start":92.64,"duration":1.8800000000000097,"text":"- 일단 들어가세요 - 감사합니다"},{"start":96.24600000000001,"duration":1.7849999999999966,"text":"손님이 많이 계시네"},{"start":100.3,"duration":1.5600000000000023,"text":"팬이에요~"},{"start":101.862,"duration":1.8979999999999961,"text":"감사합니다, 맛있게 드세요ㅎㅎ"},{"start":103.762,"duration":1.7580000000000098,"text":"여기 매니저님 계셔서"},{"start":105.521,"duration":2.429000000000002,"text":"너 때문에 소문났네"},{"start":107.952,"duration":2.347999999999999,"text":"여기 냉면이 맛있을 것 같긴 한데"},{"start":110.301,"duration":2.198999999999998,"text":"그리고 심지어 3단계의 매운맛이 있거든요"},{"start":112.50200000000001,"duration":2.4279999999999973,"text":"매운맛, 중간 매운맛, 보통 맛"},{"start":114.932,"duration":2.4080000000000013,"text":"떡국도 사장님이"},{"start":117.342,"duration":2.128,"text":"메뉴판에 없기는 한데 해주신다고 하셨거든요?"},{"start":119.47200000000001,"duration":2.937999999999988,"text":"그럼 떡국 하나, 떡만둣국 하나 일단 2개 시켜야지"},{"start":122.411,"duration":2.679000000000002,"text":"떡만 들어간 떡국 하나랑"},{"start":125.092,"duration":2.0379999999999967,"text":"그리고 떡만둣국 하나만 일단 주세요"},{"start":145.07,"duration":0.960000000000008,"text":"잘 드실지 모르겠어요"},{"start":146.032,"duration":2.617999999999995,"text":"- 너무 팬이어서ㅎㅎ - 어떡해, 너무 감사해요"},{"start":148.652,"duration":2.958000000000027,"text":"저 지금 새해 선물 왕창 받았어요"},{"start":151.612,"duration":2.1280000000000143,"text":"시장 붕어빵이랑"},{"start":153.742,"duration":1.4980000000000189,"text":"아이스티랑"},{"start":155.242,"duration":1.4680000000000177,"text":"그리고 롤케이크까지"},{"start":156.712,"duration":0.5380000000000109,"text":"감사합니다"},{"start":157.252,"duration":1.4579999999999984,"text":"새해 복 많이 받으세요, 여러분"},{"start":159.42000000000002,"duration":1.7299999999999898,"text":"페이스트리붕어빵"},{"start":161.152,"duration":5.048000000000002,"text":"하나만 먹어볼까? 선물 챙겨주신 구독자분 너무 감사합니다!"},{"start":166.202,"duration":0.8880000000000052,"text":"너무 맛있어"},{"start":167.09199999999998,"duration":1.768000000000029,"text":"사장님도 하나씩 드려야겠다"},{"start":168.862,"duration":2.4879999999999995,"text":"감사합니다, 나왔다"},{"start":171.352,"duration":2.3479999999999848,"text":"- 쯔양 씨도 맛있게 많이 먹으세요 - 너무 감사합니다"},{"start":173.702,"duration":2.127999999999986,"text":"- 새해 복 많이 받으세요, 사장님 - 네, 고마워요"},{"start":175.832,"duration":1.7980000000000018,"text":"이거 붕어빵"},{"start":177.632,"duration":1.877999999999986,"text":"손님이 주고 가신 건데"},{"start":179.512,"duration":2.098000000000013,"text":"같이 나눠 먹으면 좋을 것 같아서"},{"start":181.612,"duration":1.5879999999999939,"text":"- 고마워요 - 감사합니다"},{"start":183.202,"duration":2.9320000000000164,"text":"옆에 붕어빵 사장님"},{"start":186.136,"duration":2.6440000000000055,"text":"- 붕어빵! - 쯔양이 인기가 좋아"},{"start":188.782,"duration":3.397999999999996,"text":"저 이번 연도에 새해 복 많이 받으려나 봐요"},{"start":192.182,"duration":0.9420000000000073,"text":"잘 먹겠습니다~!"},{"start":193.126,"duration":1.9240000000000066,"text":"일단 떡국부터 먼저 먹어볼게요"},{"start":213.6,"duration":2.700000000000017,"text":"왜 겨울에 먹는 떡국은 이렇게 맛있을까?"},{"start":216.302,"duration":3.4380000000000166,"text":"진짜 원래 약간 떡국 국물에"},{"start":219.742,"duration":1.8379999999999939,"text":"계란, 참기름 막 이런 거 들어가잖아요"},{"start":221.582,"duration":3.1680000000000064,"text":"참기름도 진짜 아주 한 방울 살짝 들어간 것 같고"},{"start":224.752,"duration":3.9279999999999973,"text":"계란 없어서 되게 진짜 깔끔하고 개운한 맛이에요"},{"start":228.68200000000002,"duration":2.2029999999999745,"text":"가래떡 받아다가 쓰신대요"},{"start":230.887,"duration":1.233000000000004,"text":"떡이 진짜 맛있네"},{"start":235.7,"duration":1.200000000000017,"text":"쫀득쫀득해"},{"start":246.37,"duration":2.6299999999999955,"text":"야들야들하고 쫀득쫀득한 그 떡이에요"},{"start":253.14,"duration":3.840000000000032,"text":"떡에다가 김치 딱 올려서"},{"start":260.08,"duration":2.5,"text":"응?"},{"start":262.582,"duration":3.6380000000000337,"text":"저 생긴 거 보고 완전 겉절이일 줄 알았거든요?"},{"start":266.222,"duration":1.9680000000000177,"text":"떡국이랑 너무 잘 어울리는 김치인데?"},{"start":268.192,"duration":0.9080000000000155,"text":"신김치네?"},{"start":273.95,"duration":2.650000000000034,"text":"진짜 떡국이랑 잘 어울리는 김치다"},{"start":279.15,"duration":1.1900000000000546,"text":"맛있어요?"},{"start":280.342,"duration":1.4279999999999973,"text":"아 맛있어요"},{"start":281.772,"duration":1.608000000000004,"text":"떡이 진짜 맛있어요"},{"start":283.382,"duration":1.2180000000000177,"text":"떡만 맛있어? 다 맛있어?"},{"start":284.602,"duration":1.4080000000000155,"text":"다 맛있죠"},{"start":286.012,"duration":3.4680000000000177,"text":"- 국물 사골하고 소의 골반하고 4시간씩 고아요 - 4시간이요?"},{"start":290.05,"duration":1.829999999999984,"text":"아침 3시 반에 나와요"},{"start":291.882,"duration":1.5720000000000027,"text":"얘가 큰아들이에요"},{"start":293.456,"duration":1.69399999999996,"text":"냉면 하는 애가 큰아들"},{"start":295.152,"duration":1.268000000000029,"text":"너무 맛있어요, 사장님!"},{"start":296.422,"duration":1.2279999999999518,"text":"잘 먹겠습니다"},{"start":297.652,"duration":3.108000000000004,"text":"- 실물이 사진보다 더 예뻐! -"},{"start":300.762,"duration":1.3980000000000246,"text":"감사합니다"},{"start":302.162,"duration":1.788000000000011,"text":"새해부터 아주 예감이 좋아요"},{"start":310.87,"duration":2.829999999999984,"text":"제가 떡국을 진짜 좋아하거든요?"},{"start":313.702,"duration":2.268000000000029,"text":"어렸을 때 엄마가 사골 끓이면서"},{"start":315.972,"duration":1.462000000000046,"text":"떡국을 그렇게 많이 먹었어요"},{"start":317.436,"duration":1.274000000000001,"text":"진짜 좋아하는데"},{"start":321.11,"duration":1.7699999999999818,"text":"여기 만두가 진짜 맛있대요"},{"start":322.882,"duration":1.7280000000000086,"text":"만두를 바로 먹어보겠습니다"},{"start":324.612,"duration":1.3379999999999654,"text":"이번엔 김치만두만 들어있네"},{"start":325.952,"duration":1.52800000000002,"text":"좀 이따 고기만두 부탁드려야겠다"},{"start":327.48199999999997,"duration":4.138000000000034,"text":"원래 만두는 후추가 많아야 맛있으니까"},{"start":343.63,"duration":2.269999999999982,"text":"만두가 진짜 크고"},{"start":345.902,"duration":1.9680000000000177,"text":"푸짐하고"},{"start":347.872,"duration":3.937999999999988,"text":"알차다"},{"start":354.38,"duration":1.9600000000000364,"text":"쯔양이에요?"},{"start":356.342,"duration":1.6380000000000337,"text":"안녕하세요"},{"start":357.98199999999997,"duration":1.1130000000000564,"text":"상 축하드려요!"},{"start":359.097,"duration":1.9230000000000018,"text":"감사합니다"},{"start":366.87,"duration":4.019999999999982,"text":"만두피가 얇은 편이 아니고 살짝 두께가 있는 편인데"},{"start":370.892,"duration":3.538000000000011,"text":"되게 야들야들해요"},{"start":391.95,"duration":3.5300000000000296,"text":"- 이번에는 고기떡만둣국으로 부탁드려요 -"},{"start":395.9,"duration":0.9500000000000455,"text":"다 먹었어요?"},{"start":396.852,"duration":1.0680000000000405,"text":"네, 거의 다 먹어가요"},{"start":400.702,"duration":1.8980000000000246,"text":"이거 국물에 풀어서 먹어볼까?"},{"start":402.602,"duration":1.0540000000000305,"text":"맛있을 거 같은데?"},{"start":405.1,"duration":1.25,"text":"하나 풀어서"},{"start":406.352,"duration":1.0780000000000314,"text":"완전 이렇게 하면"},{"start":407.432,"duration":5.967999999999961,"text":"김치떡국이 됐습니다"},{"start":420.51,"duration":1.9700000000000273,"text":"여기 김치가 맛있네!"},{"start":431.652,"duration":4.7379999999999995,"text":"육수도 딱 제가 좋아하는 시원한!"},{"start":436.392,"duration":1.6680000000000064,"text":"아 여기 온육수 왜 이렇게 맛있지?"},{"start":438.062,"duration":1.2280000000000086,"text":"내가 진짜 딱 좋아하는 맛이야"},{"start":439.29200000000003,"duration":3.7379999999999427,"text":"어떻게 끓였냐고 여쭤보고 싶다"},{"start":444.65,"duration":1.3000000000000114,"text":"감사합니다"},{"start":445.952,"duration":3.117999999999995,"text":"고기떡만둣국 맛있게 먹을게요, 감사합니다"},{"start":450.25,"duration":1.6999999999999886,"text":"고기만두를 먹어보겠습니다"},{"start":451.952,"duration":2.187999999999988,"text":"만두가 진짜 커서 막 이렇게 다 부서져"},{"start":462.75,"duration":1.5,"text":"고기도 맛있어"},{"start":470,"duration":1.8600000000000136,"text":"만두 자체가 간이 안 세요"},{"start":471.862,"duration":1.8979999999999677,"text":"약간 슴슴한 매력이 있어요"},{"start":478,"duration":1.2099999999999795,"text":"맛있어요"},{"start":480.4,"duration":1.8400000000000318,"text":"만두 짱 크다"},{"start":488.88,"duration":1.3600000000000136,"text":"만두피가 되게"},{"start":490.242,"duration":1.8079999999999927,"text":"뭐라고 해야 될까?"},{"start":496.252,"duration":2.4979999999999905,"text":"쫀득쫀득해서 맛있는 피 말고"},{"start":498.752,"duration":2.0079999999999814,"text":"엄청 부들부들해서"},{"start":500.762,"duration":1.4580000000000268,"text":"입안에 닿는 느낌이"},{"start":502.222,"duration":2.0680000000000405,"text":"부드러워서 맛있는 만두피 아시죠?"},{"start":508.9,"duration":2.5,"text":"김치가 제일 잘 어울려"},{"start":527.9,"duration":2.25,"text":"만두 터트린 국"},{"start":532.92,"duration":2.240000000000009,"text":"아 근데 사실"},{"start":535.1610000000001,"duration":3.06899999999996,"text":"저는 30살 되기 전까지는"},{"start":538.232,"duration":2.197999999999979,"text":"실감이 계속 안 났거든요? '내가 30살이라고?'"},{"start":540.431,"duration":1.2289999999999281,"text":"막상 되고 나니까"},{"start":541.661,"duration":2.0990000000000464,"text":"똑같네"},{"start":543.762,"duration":1.7080000000000837,"text":"오히려 적게 먹은 것 같아요"},{"start":545.472,"duration":3.1280000000000427,"text":"나 한 35살 된 것 같은데"},{"start":548.602,"duration":2.6680000000000064,"text":"30살 되기 2~3년 전에는 되게 되기 싫어헸거든요"},{"start":551.271,"duration":1.2990000000000919,"text":"근데 막상 되니까"},{"start":552.572,"duration":2.467999999999961,"text":"좋아요, 약간 새로운 인생"},{"start":555.041,"duration":0.8990000000000009,"text":"그냥 받아들인 거 아닐까?"},{"start":555.942,"duration":2.298000000000002,"text":"어쩔 수 없는 거니까"},{"start":572.69,"duration":2.0699999999999363,"text":"떡국 3그릇 먹었으니까"},{"start":574.762,"duration":2.6680000000000064,"text":"떡국 한 그릇에 나이 한 살이라고 하잖아요"},{"start":577.431,"duration":2.338999999999942,"text":"그렇게 치면 100살이 이미 넘었어요"},{"start":579.771,"duration":2.869000000000028,"text":"작년에만 이미 10그릇 먹었는데"},{"start":585.21,"duration":1.8299999999999272,"text":"이제 친구 합시다"},{"start":588.942,"duration":1.9080000000000155,"text":"어머 안녕하세요"},{"start":594.352,"duration":1.9680000000000746,"text":"너무해, 상처받았어"},{"start":596.322,"duration":3.018000000000029,"text":"떡집에서 오셨어요, 떡 맛있다고~"},{"start":599.342,"duration":1.1580000000000155,"text":"떡이 너무 맛있어요, 사장님"},{"start":600.502,"duration":2.3880000000000337,"text":"- 아주 너무너무 잘해 - 떡 너무 맛있게 먹었어요"},{"start":602.891,"duration":1.3000000000000682,"text":"- 손녀딸 - 안녕하세요"},{"start":604.193,"duration":0.9669999999999845,"text":"언니 안녕?"},{"start":605.161,"duration":1.3690000000000282,"text":"언니하