?"},{"start":469.427,"duration":4.030999999999949,"text":"안녕하세요, 너무 맛있게 잘 먹을게요"},{"start":473.46,"duration":1.8149999999999977,"text":"감사합니다"},{"start":495.185,"duration":2.6299999999999955,"text":"가슴살만 미리 공략하고 있어요"},{"start":497.817,"duration":1.117999999999995,"text":"다른 거 안 먹고"},{"start":499.715,"duration":3.302000000000021,"text":"닭 가슴살 이렇게 쌓아놓고 먹은 적 처음인 거 같아"},{"start":529.995,"duration":2.4039999999999964,"text":"근데 닭이 되게 고소하다"},{"start":532.401,"duration":3.3640000000000327,"text":"뭔가 씹을수록 살짝 고소한 맛이 엄청 올라와요"},{"start":544.301,"duration":1.01400000000001,"text":"근데"},{"start":545.997,"duration":1.1140000000000327,"text":"이거, 응?"},{"start":549.708,"duration":2.282000000000039,"text":"진짜 신기한 게 뭔지 아세요?"},{"start":551.992,"duration":2.441000000000031,"text":"옷을 처음 사고 처음 입잖아요"},{"start":554.435,"duration":1.3100000000000591,"text":"그럼 무조건 이렇게 돼요"},{"start":555.747,"duration":0.77800000000002,"text":"항상"},{"start":556.526,"duration":2.119000000000028,"text":"대참사가 일어나"},{"start":558.646,"duration":1.8540000000000418,"text":"왜 그러는 걸까? 신고식인가?"},{"start":563.319,"duration":1.725999999999999,"text":"- 안녕하세요 - 안녕하세요"},{"start":565.046,"duration":3.79099999999994,"text":"저를 대신해서 2대로 이 가게를 운영해 나갈 친구"},{"start":568.8389999999999,"duration":1.2260000000001128,"text":"아 정말요?"},{"start":570.067,"duration":1.0900000000000318,"text":"천천히 배우고 있습니다"},{"start":571.159,"duration":1.6409999999999627,"text":"아 지금 배우고 계신 거예요?"},{"start":574.705,"duration":1.3549999999999045,"text":"대를 이어서"},{"start":576.775,"duration":3.800000000000068,"text":"뭔가 아드님이나 따님이 물려받는다고 하면은"},{"start":580.577,"duration":1.4080000000000155,"text":"되게 좋을 것 같거든요"},{"start":581.987,"duration":2.798000000000002,"text":"이 맛을 계속 먹을 수 있으니까"},{"start":585.505,"duration":1.9800000000000182,"text":"와... 안에 감자 드디어 먹어볼까?"},{"start":587.487,"duration":4.0890000000000555,"text":"저 이렇게 부서진 감자를 너무 좋아해요"},{"start":591.578,"duration":3.1800000000000637,"text":"그래서 일부러 부서질 때까지 끓였습니다"},{"start":594.76,"duration":2.034999999999968,"text":"국물을 살짝 떠서"},{"start":611.615,"duration":2.5499999999999545,"text":"와 제가 이거 먹으려고 열심히 끓였거든요?"},{"start":614.166,"duration":2.078999999999951,"text":"너무 좋다"},{"start":639.085,"duration":4.860000000000014,"text":"원래 닭 부위 중에 봉을 많이 드시잖아요"},{"start":643.947,"duration":2.1760000000000446,"text":"봉이 은근 되게 퍽퍽하거든요?"},{"start":646.125,"duration":3.705000000000041,"text":"근데 여기는 봉도 되게 쫄깃쫄깃하다"},{"start":649.832,"duration":1.6989999999999554,"text":"이렇게 으깨서"},{"start":661.6,"duration":2.7450000000000045,"text":"원래"},{"start":664.347,"duration":4.548000000000002,"text":"닭갈비에는 고구마 들어가잖아요"},{"start":668.896,"duration":2.5590000000000828,"text":"전 그때마다 되게 서러웠거든요"},{"start":671.457,"duration":3.3079999999999927,"text":"제가 진짜 좋은 생각이 났거든요?"},{"start":674.766,"duration":3.033999999999992,"text":"닭살을 여기에 발라서 넣은 다음에 막 떠먹어"},{"start":677.801,"duration":2.641999999999939,"text":"맛있겠다"},{"start":681.672,"duration":2.3279999999999745,"text":"여기다가 발라서"},{"start":684.002,"duration":13.393000000000029,"text":"시작!)"},{"start":697.396,"duration":0.9039999999999964,"text":"여기다가 이렇게 발라놓고"},{"start":700.602,"duration":2.994000000000028,"text":"바르면서..."},{"start":703.598,"duration":3.1030000000000655,"text":"바르면서 반은 먹은 거 같아"},{"start":706.703,"duration":2.0299999999999727,"text":"바로 이거 볶음밥에 넣으려고 했는데"},{"start":708.734,"duration":2.7619999999999436,"text":"여기에다가 이렇게 뿌려 먹어도 맛있을 것 같아"},{"start":711.497,"duration":3.6450000000000955,"text":"여기다가 볶음밥 하면 진짜 끝장날 거 같거든요?"},{"start":715.645,"duration":3.9049999999999727,"text":"원래 볶음밥 할 때 혹은"},{"start":719.551,"duration":2.6089999999999236,"text":"혹은 찜닭 먹고 밥 비벼 먹을 때"},{"start":722.161,"duration":1.9390000000000782,"text":"감자 넣고 으깨 먹으면 진짜..."},{"start":724.102,"duration":1.6480000000000246,"text":"진짜 맛있습니다"},{"start":725.752,"duration":3.80600000000004,"text":"저는 그래서 항상 샤부샤부 죽 할 때도"},{"start":729.56,"duration":1.850999999999999,"text":"감자 으깨서 먹으면 진짜 맛있거든요"},{"start":731.412,"duration":2.6929999999999836,"text":"그래서 저는 다 항상 감자를 남겨놓고"},{"start":734.107,"duration":1.9930000000000518,"text":"마지막에 으깨서 같이 밥 비벼 먹어요"},{"start":743.845,"duration":2.92999999999995,"text":"볶아 먹기 전에 몇 숟갈만 퍼먹자"},{"start":764.585,"duration":4.036999999999921,"text":"사장님 여기 밥 하나만 해주세요"},{"start":768.623,"duration":1.3299999999999272,"text":"감사합니다"},{"start":773.955,"duration":1.9319999999999027,"text":"진짜 맛있겠다"},{"start":779.625,"duration":1.6749999999999545,"text":"감사합니다"},{"start":783.345,"duration":2.55499999999995,"text":"찜닭은 안 볶아 먹고 비벼 먹잖아요"},{"start":785.901,"duration":2.899000000000001,"text":"그런 것처럼 지금 딱 농도도 좋고 너무 좋거든요"},{"start":788.801,"duration":3.44399999999996,"text":"그래서 불을 약불로 최대한 줄이고 바로 먹을게요"},{"start":793.416,"duration":1.3339999999999463,"text":"이걸로 먹어도 되나?"},{"start":794.752,"duration":2.5230000000000246,"text":"사장님 이걸로 먹어도 돼요?"},{"start":804.515,"duration":2.7100000000000364,"text":"이거는 약간 볶음밥이 아니라"},{"start":807.227,"duration":2.272000000000048,"text":"제가 감자를 많이 으깨놔서"},{"start":809.501,"duration":2.13900000000001,"text":"찜닭 남은 거에 비벼 먹는 느낌"},{"start":811.641,"duration":2.3659999999999854,"text":"사실은 이거 나오는 음식은 아닌데"},{"start":814.008,"duration":2.641999999999939,"text":"사장님이 집 깻잎을 조금 주셨거든요"},{"start":824.702,"duration":2.6649999999999636,"text":"오늘 베스트 한 입이었어"},{"start":828.848,"duration":2.997000000000071,"text":"닭갈비 양념장을 여기에다가 다 때려 넣어서"},{"start":831.847,"duration":3.4680000000000746,"text":"진짜 밥보다 양념이 많은데도 안 짜요"},{"start":835.317,"duration":3.9279999999999973,"text":"근데 맛있어요"},{"start":844.35,"duration":1.5559999999999263,"text":"와 진짜 맛있다"},{"start":846.478,"duration":1.8269999999999982,"text":"볶아진 부분이 더 맛있네?"},{"start":873.04,"duration":2.9600000000000364,"text":"먹으니까 해장도 다 됐는데"},{"start":876.002,"duration":1.6829999999999927,"text":"뭔가..."},{"start":877.686,"duration":3.130999999999972,"text":"배고파졌어"},{"start":897.276,"duration":1.907000000000039,"text":"와 너무 맛있어서"},{"start":899.185,"duration":1.1560000000000628,"text":"숟가락이 안 멈춰~!"},{"start":905.55,"duration":1.6050000000000182,"text":"덜 드신 것 같아요, 양이 안 차신 것 같아"},{"start":907.156,"duration":3.5289999999999964,"text":"맞아요, 지금 애피타이저 먹어서ㅎㅎ"},{"start":910.686,"duration":3.4569999999999936,"text":"오랜만에 약간 막 자극적인 게 아니라"},{"start":914.145,"duration":1.6090000000000373,"text":"속 편한 거 먹어서"},{"start":915.756,"duration":2.479000000000042,"text":"오히려 지금 입맛이 더 살아났어요"},{"start":918.237,"duration":2.5579999999999927,"text":"맨날 제가 요즘 음식을 되게 짜게 먹거든요"},{"start":920.796,"duration":3.328999999999951,"text":"뭔가 오랜만에 되게 슴슴하면서도"},{"start":924.127,"duration":3.0730000000000928,"text":"좀 뭔가 건강하게 먹은 느낌이라 좋았습니다"},{"start":927.202,"duration":2.40300000000002,"text":"물닭갈비가 확실히 겨울에 먹기 너무 좋은 것 같아요"},{"start":929.607,"duration":1.447999999999979,"text":"약간 진짜 전혀 다른 매력이었어요"},{"start":931.056,"duration":1.81899999999996,"text":"여태까지 제가 못 먹어본?"},{"start":932.877,"duration":2.008000000000038,"text":"저는 다음"},{"start":934.887,"duration":2.8730000000000473,"text":"다음 식사를 하러 가보겠습니다"},{"start":937.762,"duration":4.026000000000067,"text":"아무튼 오늘도 잘 먹었습니다~!"}],"recollect_id":0,"recollect_vars":["new_video"],"collector_source":"yt-dlp"}
