000103,"text":"소, 중, 대, 특대가 있네?"},{"start":85.711,"duration":2.0940000000000083,"text":"사장님 특대로 부탁드립니다"},{"start":87.807,"duration":0.9380000000000024,"text":"예 예 예"},{"start":88.747,"duration":1.7809999999999917,"text":"감사합니다"},{"start":111.175,"duration":1.1620000000000061,"text":"양 진짜 많다"},{"start":114.13499999999999,"duration":1.5100000000000193,"text":"안에 떡도 있고"},{"start":115.646,"duration":2.929000000000002,"text":"파랑 버섯이랑..."},{"start":118.577,"duration":1.9080000000000013,"text":"콩나물도 있고"},{"start":120.487,"duration":2.308000000000007,"text":"국물만 살짝 먹어볼까...?"},{"start":122.797,"duration":2.179000000000002,"text":"너무 먹어보고 싶어, 어떨지"},{"start":131.198,"duration":2.526999999999987,"text":"일단 처음에는 엄청 슴슴하거든요?"},{"start":133.727,"duration":3.4480000000000075,"text":"푹 끓이면 왠지 진국일 것 같은데...?"},{"start":139.738,"duration":0.9610000000000127,"text":"좋다"},{"start":140.701,"duration":3.048000000000002,"text":"근데 이 슴슴함이 너무 좋다"},{"start":143.75,"duration":1.8379999999999939,"text":"감사합니다"},{"start":145.59,"duration":1.4749999999999943,"text":"면이 굵네?!"},{"start":147.067,"duration":0.8580000000000041,"text":"굵은 면!"},{"start":147.927,"duration":1.1180000000000234,"text":"다른 면으로 드릴까?"},{"start":149.047,"duration":1.2980000000000018,"text":"오 아니요! 굵은 면 먹어볼게요ㅎㅎ"},{"start":150.347,"duration":1.0819999999999936,"text":"감사합니다"},{"start":151.945,"duration":1.3550000000000182,"text":"면이 굵다"},{"start":154.75900000000001,"duration":2.334000000000003,"text":"여기 라면 사리에다가"},{"start":158.699,"duration":1.1869999999999834,"text":"라면 사리부터"},{"start":163.70499999999998,"duration":1.9800000000000182,"text":"국물이 아직 살짝 슴슴해서"},{"start":165.687,"duration":2.509999999999991,"text":"김치 딱 올려 먹으면 맞을 것 같아"},{"start":183,"duration":0.9329999999999927,"text":"맛있다"},{"start":185.985,"duration":1.4949999999999761,"text":"김치 맛있네"},{"start":203.181,"duration":2.5239999999999725,"text":"원래 해장라면이 맛있는 거거든요"},{"start":205.707,"duration":1.617999999999995,"text":"어우 너무 좋다"},{"start":244.615,"duration":0.924999999999983,"text":"아니 안에 이게"},{"start":245.542,"duration":3.4329999999999927,"text":"닭갈비가 우리가 아는 순살 닭갈비가 아니라"},{"start":248.977,"duration":1.2079999999999984,"text":"뼈 닭갈비예요"},{"start":250.187,"duration":2.7779999999999916,"text":"뼈랑 되게 잘게 썰려있는..."},{"start":252.967,"duration":1.7009999999999934,"text":"부위도 여러 가지 다 있거든요?"},{"start":255.385,"duration":1.0550000000000068,"text":"닭 가슴살"},{"start":259.605,"duration":4.154999999999973,"text":"저 방금 닭 가슴살 먹은 것 같은데...?"},{"start":263.762,"duration":0.90300000000002,"text":"어라?"},{"start":264.66700000000003,"duration":6.132999999999981,"text":"닭 가슴살..."},{"start":273.067,"duration":2.091000000000008,"text":"제가 닭 가슴살 잘 못 먹잖아요"},{"start":275.15999999999997,"duration":2.625,"text":"닭 가슴살이 좀 부드럽다"},{"start":277.787,"duration":2.4920000000000186,"text":"되게 퍽퍽하고 질겅하지 않고"},{"start":280.281,"duration":2.652999999999963,"text":"닭 안심살 정도 되는 식감...?"},{"start":282.936,"duration":1.8389999999999986,"text":"내가 안심을 먹었나...?"},{"start":290.755,"duration":3.079999999999984,"text":"밀떡은 또 넣자마자 먹어야 맛있는데"},{"start":293.837,"duration":3.348000000000013,"text":"그래서 사장님이 떡 먼저 먹으라고 하셨구나"},{"start":309.035,"duration":0.9739999999999895,"text":"좋다"},{"start":311.635,"duration":2.879000000000019,"text":"약간 어떤 느낌이냐면요"},{"start":314.516,"duration":1.9209999999999923,"text":"닭갈비도 전혀 아니고요"},{"start":316.439,"duration":1.9559999999999604,"text":"닭볶음탕 맛도 아니고요"},{"start":318.397,"duration":2.848000000000013,"text":"그나마 닭매운탕 예전에 먹었던 거랑 비슷한데"},{"start":321.247,"duration":1.8929999999999723,"text":"그것보다도 훨씬 슴슴하거든요?"},{"start":325.038,"duration":2.086999999999989,"text":"제가 또 이런 약간 슴슴한 국물 너무 좋아하거든요"},{"start":327.127,"duration":1.6619999999999777,"text":"이게 먹어도 먹어도 안 질리고"},{"start":328.791,"duration":3.7139999999999986,"text":"입도 안 텁텁해지고 입에서 되게 깔끔해요"},{"start":342.255,"duration":4.840000000000032,"text":"이거 국물에 넣어 먹는 양념장을 주셨거든요?"},{"start":347.097,"duration":1.677000000000021,"text":"국물을 살짝 퍼서"},{"start":359.438,"duration":2.687000000000012,"text":"와 완전 얼큰해진다"},{"start"