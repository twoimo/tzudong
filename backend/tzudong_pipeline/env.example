# ============================================
# 🍜 Tzudong Pipeline Environment Variables
# ============================================

# ===== GitHub =====
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_github_repo

# ===== YouTube 메타데이터 수집 =====
YOUTUBE_API_KEY=your_youtube_api_key

# ===== OpenAI (영상 캡션 광고 검사) =====
OPENAI_API_KEY=your_openai_api_key

# ===== Naver 지오코딩 =====
NAVER_GEOCODING_CLIENT_ID=your_naver_geocoding_client_id
NAVER_GEOCODING_CLIENT_SECRET=your_naver_geocoding_client_secret

# ===== Naver 검색 API =====
NAVER_SEARCH_CLIENT_ID=your_naver_search_client_id
NAVER_SEARCH_CLIENT_SECRET=your_naver_search_client_secret

# ===== Oracle DB (PostgreSQL OR Supabase) =====
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_DSN=your_oracle_dsn
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# ===== Gemini OAuth (.gemini Folder)=====
GEMINI_ACCESS_TOKEN=your_gemini_access_token
GEMINI_REFRESH_TOKEN=your_gemini_refresh_token

# ===== Pipeline Settings =====
# 실행 환경 (local, oracle, github_actions)
PIPELINE_ENV=local

# 기본 타겟 채널 (tzuyang, jeongyukwang 등)
DEFAULT_CHANNEL=tzuyang

# Gemini 모델 설정
GEMINI_MODEL=gemini-3.0-flash

# 병렬 처리 워커 수
PARALLEL_WORKERS=2

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 한국 시간대
TIMEZONE=Asia/Seoul
