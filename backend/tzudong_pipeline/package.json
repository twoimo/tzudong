{
    "name": "tzudong-pipeline",
    "version": "2.0.0",
    "description": "YouTube 맛집 데이터 자동화 파이프라인 - 통합 리팩토링 버전",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "tsx scripts/pipeline.ts",
