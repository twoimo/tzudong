        "db:insert": "tsx scripts/database/insert_oracle.ts",
        "db:sync": "tsx scripts/database/sync_supabase.ts",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@google/generative-ai": "^0.2.0",
        "@supabase/supabase-js": "^2.39.0",
        "dotenv": "^16.3.1",
