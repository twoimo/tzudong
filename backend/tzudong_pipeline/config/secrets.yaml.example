# ============================================
# 🔐 Secrets Configuration (Example)
# ============================================
# 이 파일을 secrets.yaml로 복사하고 실제 값을 입력하세요.
# secrets.yaml은 .gitignore에 추가되어 있습니다.

# ===== GitHub =====
github:
  token: "your_github_token"
  owner: "your_github_owner"
  repo: "your_github_repo"

# ===== YouTube 메타데이터 수집 =====
youtube:
  api_key: "your_youtube_api_key"

# ===== OpenAI (영상 캡션 광고 검사) =====
openai:
  api_key: "your_openai_api_key"

# ===== Naver 지오코딩 =====
naver_geocoding:
  client_id: "your_naver_geocoding_client_id"
  client_secret: "your_naver_geocoding_client_secret"

# ===== Naver 검색 API =====
naver_search:
  client_id: "your_naver_search_client_id"
  client_secret: "your_naver_search_client_secret"

# ===== Oracle DB =====
oracle:
  user: "your_oracle_user"
  password: "your_oracle_password"
  dsn: "your_oracle_dsn"

# ===== Supabase =====
supabase:
  url: "your_supabase_url"
  key: "your_supabase_key"

# ===== Gemini OAuth =====
# .gemini/oauth_creds.json 파일에서 자동 로드됨
# 또는 아래에 직접 입력
gemini:
  access_token: "your_gemini_access_token"
  refresh_token: "your_gemini_refresh_token"
  token_type: "Bearer"
  expiry_date: 0
