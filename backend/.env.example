# =================================
# tzudong Backend Environment Variables
# =================================
# 이 파일을 backend/.env로 복사하고 실제 값을 입력하세요
# cp .env.example .env

# =================================
# YouTube Data API
# =================================
YOUTUBE_API_KEY_BYEON=your_youtube_api_key

# =================================
# OpenAI API (광고 분석용)
# =================================
OPENAI_API_KEY_BYEON=your_openai_api_key

# =================================
# Google Gemini API
# =================================
GEMINI_API_KEY=your_gemini_api_key

# =================================
# Naver API (지오코딩, 장소 검색)
# =================================
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver Cloud Platform Maps API (선택사항)
NCP_MAPS_KEY_ID=your_ncp_maps_key_id
NCP_MAPS_KEY=your_ncp_maps_key

# =================================
# Kakao API (지도, 장소 검색)
# =================================
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# =================================
# Supabase
# =================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =================================
# Puppeteer (GitHub Actions용)
# =================================
# GitHub Actions에서 자동 설정됨
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# =================================
# 파이프라인 설정 (선택사항)
# =================================
# GitHub Actions에서 자동 설정됨
# PIPELINE_DATE=26-01-09

# 디버그 모드 (true/false)
# DEBUG=false
