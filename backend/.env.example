# =================================
# tzudong Backend Environment Variables
# =================================
# 이 파일을 backend/.env로 복사하고 실제 값을 입력하세요
# cp .env.example .env

# =================================
# YouTube Data API
# =================================
YOUTUBE_API_KEY_BYEON=your_youtube_api_key

# =================================
# OpenAI API (광고 분석용)
# =================================
OPENAI_API_KEY_BYEON=your_openai_api_key

# =================================
# Google Gemini API
# =================================
# GEMINI_API_KEY 또는 GEMINI_API_KEY_BYEON 둘 다 가능
GEMINI_API_KEY=your_gemini_api_key

# =================================
# Naver API (지역 검색)
# =================================
NAVER_CLIENT_ID_BYEON=your_naver_client_id
NAVER_CLIENT_SECRET_BYEON=your_naver_client_secret

# =================================
# Naver Cloud Platform Maps API (지오코딩)
# =================================
NCP_MAPS_KEY_ID_BYEON=your_ncp_maps_key_id
NCP_MAPS_KEY_BYEON=your_ncp_maps_key

# =================================
# Supabase
# =================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
