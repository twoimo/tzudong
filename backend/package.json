{
  "name": "tzudong-crawler",
  "version": "1.0.0",
  "description": "Puppeteer crawler for extracting restaurant information from Perplexity AI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "process": "tsx src/process-remaining.ts",
    "test-process": "TEST_MODE=true tsx src/process-remaining.ts",
    "manual-start": "MANUAL_MODE=true npm run start",
    "test-login": "tsx test-login-detection.ts",
    "test-input": "tsx test-input-method.ts",
    "test-full": "tsx test-full-process.ts",
    "reset": "node reset-data.js"
  },
  "dependencies": {
    "puppeteer": "^23.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
