FROM node:20-slim

# Install Gemini CLI and jq
RUN apt-get update && apt-get install -y jq && npm install -g @google/gemini-cli && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# The entrypoint doesn't matter much as we'll use docker exec
# But keeping it alive with tail -f /dev/null is a common pattern for daemons
CMD ["tail", "-f", "/dev/null"]
