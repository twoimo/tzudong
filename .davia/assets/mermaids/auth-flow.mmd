%%{init: {'theme': 'default'}}%%

sequenceDiagram
    autonumber
    participant U as User
    participant F as Frontend
    participant A as AuthContext
    participant S as Supabase Auth
    participant DB as Database
    participant R as RLS

    rect rgb(230, 255, 237)
        Note over U,R: LOGIN FLOW
        U->>F: Open Login Modal
        U->>F: Enter Email/Password
        F->>A: signIn(email, password)
        A->>S: signInWithPassword()
        S-->>A: Return Session + JWT
        A->>DB: checkAdminRole()
        DB->>R: Check user_roles table
        A->>DB: checkProfileStatus()
        A-->>F: Update Auth State (isAdmin, user)
        F-->>U: Login Success + Redirect
    end

    rect rgb(255, 243, 224)
        Note over U,R: SIGNUP FLOW
        U->>F: Enter Email/Password/Nickname
        F->>F: Validate Nickname (Unique)
        F->>A: signUp(email, password, nickname)
        A->>S: auth.signUp()
        S->>DB: Create User in auth.users
        DB->>DB: Trigger: Create Profile
        S-->>A: Return Success
        F-->>U: Signup Complete
    end

    rect rgb(237, 233, 254)
        Note over U,R: SESSION MANAGEMENT
        F->>A: onAuthStateChange()
        A->>S: Get Current Session
        S-->>A: Session or null
        A->>DB: Refresh Profile & Role
        A-->>F: Update Global Auth State
    end

    rect rgb(255, 235, 235)
        Note over U,R: PROTECTED ROUTES
        U->>F: Access Admin Page
        F->>A: Check isAdmin
        alt Is Admin
            F-->>U: Show Admin Dashboard
        else Not Admin
            F-->>U: Redirect to Home
        end
    end
