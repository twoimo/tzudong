%%{init: {'theme': 'default'}}%%

erDiagram
    profiles ||--o{ reviews : writes
    profiles ||--o{ user_roles : has
    profiles ||--o{ restaurant_submissions : submits
    
    restaurants ||--o{ reviews : has
    restaurants ||--o| restaurant_evaluations : evaluated_by
    
    restaurant_submissions ||--o| restaurants : creates

    profiles {
        uuid user_id PK
        string nickname UK
        string email
    }
    
    restaurants {
        uuid id PK
        string name
        float lat
        float lng
        string status
    }
    
    reviews {
        uuid id PK
        uuid user_id FK
        uuid restaurant_id FK
        text content
    }
    
    restaurant_evaluations {
        uuid id PK
        int rule_score
        int laaj_score
        bool is_selected
    }
    
    restaurant_submissions {
        uuid id PK
        uuid user_id FK
        string status
    }
    
    user_roles {
        uuid id PK
        uuid user_id FK
        string role
    }
