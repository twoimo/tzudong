flowchart TB
    subgraph INPUT["1. INPUT"]
        direction TB
        I1[/"YouTube Video URLs"/]
        I2["Transcript API<br/>(FastAPI Server)"]
        I3[("Subtitle Text<br/>+ Timestamps")]
    end

    subgraph CRAWL["2. CRAWLING"]
        direction TB
        C1["Load Gemini Prompt"]
        C2["Gemini CLI<br/>AI Processing"]
        C3["Extract Restaurant Info<br/>(name, reason, menu)"]
        C4[("crawling-results.jsonl")]
    end

    subgraph EVAL["3. EVALUATION"]
        direction TB
        E1["RULE Score<br/>(address, timestamp)"]
        E2["LAAJ Score<br/>(AI verification)"]
        E3{"Total Score<br/>>= 70?"}
        E4(["SELECTED<br/>for DB"])
        E5(["NOT SELECTED<br/>evaluation only"])
    end

    subgraph TRANSFORM["4. TRANSFORM"]
        direction TB
        T1["Naver Geocoding API<br/>(get coordinates)"]
        T2["Duplicate Check<br/>(similar name/address)"]
        T3["Generate unique_id<br/>(hash based)"]
    end

    subgraph DB["5. DATABASE"]
        direction TB
        D1[("restaurant_evaluations<br/>all evaluation results")]
        D2[("restaurants<br/>verified data only")]
    end

    I1 --> I2
    I2 --> I3
    I3 --> C1
    C1 --> C2
    C2 --> C3
    C3 --> C4

    C4 --> E1
    E1 --> E2
    E2 --> E3
    E3 -->|"Pass"| E4
    E3 -->|"Fail"| E5

    E4 --> T1
    T1 --> T2
    T2 --> T3

    E5 --> D1
    T3 --> D2
    D2 -.->|"link"| D1

    style INPUT fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    style CRAWL fill:#dcfce7,stroke:#22c55e,stroke-width:2px
    style EVAL fill:#fef9c3,stroke:#eab308,stroke-width:2px
    style TRANSFORM fill:#fce7f3,stroke:#ec4899,stroke-width:2px
    style DB fill:#e0e7ff,stroke:#6366f1,stroke-width:2px
