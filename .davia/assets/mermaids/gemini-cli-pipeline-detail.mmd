    end

    %% ===== Phase 2: AI 크롤링 =====
    subgraph PHASE2["🕷️ Phase 2: AI 크롤링 (geminiCLI-restaurant-crawling)"]
        direction TB
        
        subgraph CRAWL_CONFIG["⚙️ 크롤링 설정"]
            CC1["📜 프롬프트 파일<br/>───────────────────<br/>prompts/01-extract-restaurants.md<br/>├─ 시스템 역할 정의<br/>├─ 추출 필드 지정<br/>├─ 출력 형식 지정<br/>└─ 예시 포함"]
            CC2["⚡ 실행 스크립트<br/>───────────────────<br/>scripts/crawl-restaurants.ts<br/>├─ 배치 처리 (10개씩)<br/>├─ 재시도 로직 (3회)<br/>├─ 진행률 로깅<br/>└─ 결과 저장"]
        end
        
        subgraph CRAWL_EXEC["🚀 Gemini CLI 실행"]
            CE1["🤖 명령어<br/>───────────────────<br/>gemini \\ <br/>  --model gemini-2.5-pro \\<br/>  --prompt {prompt_file} \\<br/>  --input {transcript} \\<br/>  --sandbox"]
            CE2["🧠 AI 분석 작업<br/>───────────────────<br/>1. 자막 텍스트 분석<br/>2. 맛집 언급 감지<br/>3. 정보 추출<br/>   • 식당명<br/>   • 주소<br/>   • 카테고리<br/>   • 쯔양 코멘트"]
        end
        
        subgraph CRAWL_OUTPUT["📤 크롤링 결과"]
            CO1["📊 결과 파일<br/>───────────────────<br/>data/crawling-results.jsonl<br/>├─ JSON Lines 형식<br/>└─ 영상당 1+ 레코드"]
            CO2["📋 결과 스키마<br/>───────────────────<br/>{<br/>  video_id,<br/>  video_title,<br/>  restaurant_name,<br/>  address,<br/>  category,<br/>  tzuyang_comment,<br/>  confidence_score,<br/>  extracted_at<br/>}"]
        end
    end

    %% ===== Phase 3: AI 평가 =====
    subgraph PHASE3["⭐ Phase 3: AI 평가 (geminiCLI-restaurant-evaluation)"]
        direction TB
        
        subgraph EVAL_CONFIG["⚙️ 평가 설정"]
            EC1["📜 평가 프롬프트<br/>───────────────────<br/>prompts/01-evaluate-restaurant.md<br/>├─ 선정 기준 정의<br/>├─ 점수 체계 설명<br/>└─ 판단 가이드라인"]
            EC2["⚡ 평가 스크립트<br/>───────────────────<br/>scripts/evaluate-restaurants.ts<br/>├─ 순차 처리<br/>├─ 점수 계산<br/>└─ 결과 저장"]
        end
        
        subgraph EVAL_RULES["📏 RULE 평가 (규칙 기반)"]
            ER1["✓ 필수 필드 검사<br/>───────────────────<br/>• restaurant_name 존재<br/>• address 존재<br/>• video_id 유효"]
            ER2["✓ 형식 검사<br/>───────────────────<br/>• 주소 형식 유효성<br/>• 카테고리 유효성<br/>• 텍스트 길이 검사"]
            ER3["📊 RULE 점수<br/>───────────────────<br/>rule_score: 0-100<br/>각 항목 가중치 합산"]
        end
        
        subgraph EVAL_LAAJ["🤖 LAAJ 평가 (AI 판단)"]
            EL1["🧠 AI 판단 기준<br/>───────────────────<br/>• 실제 맛집인가?<br/>• 쯔양이 방문했나?<br/>• 정보가 정확한가?<br/>• 영업 중인가?"]
            EL2["📊 LAAJ 점수<br/>───────────────────<br/>laaj_score: 0-100<br/>AI confidence 기반"]
        end
        
        subgraph EVAL_FINAL["📊 최종 평가"]
            EF1["🔢 종합 점수<br/>───────────────────<br/>total = rule_score * 0.4<br/>      + laaj_score * 0.6"]
            EF2{"🔀 임계값 비교<br/>threshold = 70"}
            EF3["✅ 선정<br/>is_selected = true"]
            EF4["❌ 미선정<br/>is_selected = false"]
        end
    end

    %% ===== Phase 4: 변환 & 저장 =====
    subgraph PHASE4["💾 Phase 4: 변환 & 데이터베이스 저장"]
        direction TB
        
        subgraph TRANSFORM["🔄 데이터 변환"]
            TF1["🗺️ Naver Geocoding<br/>───────────────────<br/>POST /map-geocode/v2/geocode<br/>├─ 도로명 주소 변환<br/>├─ 지번 주소 변환<br/>├─ 영문 주소 생성<br/>└─ 좌표 (lat, lng)"]
            TF2["🔍 중복 검사<br/>───────────────────<br/>Levenshtein Distance<br/>├─ 이름 유사도 85%↑<br/>├─ 같은 지번주소<br/>└─ 기존 데이터 병합"]
            TF3["🔑 unique_id 생성<br/>───────────────────<br/>format: {name}_{address}<br/>해시 기반 고유 식별자"]
        end
        
        subgraph DB_INSERT["🗄️ 데이터베이스 저장"]
            DI1["📊 restaurant_evaluations<br/>───────────────────<br/>INSERT INTO<br/>├─ crawling_data (JSONB)<br/>├─ rule_score<br/>├─ laaj_score<br/>├─ is_selected<br/>└─ processed_at"]
            DI2["🍽️ restaurants<br/>───────────────────<br/>INSERT INTO (선정된 것만)<br/>├─ name, address<br/>├─ lat, lng<br/>├─ categories[]<br/>├─ youtube_link<br/>├─ evaluation_id (FK)<br/>└─ status = 'approved'"]
        end
    end

