%%{init: {'theme': 'default'}}%%

sequenceDiagram
    autonumber
    participant U as User
    participant F as Frontend
    participant S as Supabase
    participant OCR as Gemini OCR
    participant A as Admin
    participant N as Notification

    rect rgb(230, 255, 237)
        Note over U,N: SUBMIT RESTAURANT
        U->>F: Click Submit Button
        F->>F: Check Login Status
        U->>F: Fill Form (Name, YouTube URL, Address)
        F->>S: INSERT submission
        S-->>U: Success Toast
    end

    rect rgb(255, 243, 224)
        Note over U,N: ADMIN REVIEW
        A->>S: Query Pending Submissions
        A->>A: Watch YouTube & Verify
        A->>A: Geocode Address
        A->>A: Check Duplicate (Name+Address)
        alt Approve
            A->>S: INSERT restaurant
            A->>S: UPDATE status=approved
            S->>N: Create Notification
            N-->>U: Push Alert
        else Reject
            A->>S: UPDATE status=rejected with reason
        end
    end

    rect rgb(255, 235, 235)
        Note over U,N: RECEIPT OCR STAMP
        U->>F: Upload Receipt Image
        F->>S: Store Image in Storage
        F->>OCR: Call Gemini Vision API
        OCR-->>F: Extract (Store, Date, Amount)
        F->>S: Check Duplicate Receipt
        S-->>F: Duplicate Check Result
        F->>S: INSERT receipt record
        A->>S: Review Receipt
        alt Approve
            A->>S: UPDATE status=approved
            S->>S: Award Stamp to User
            N-->>U: Stamp Awarded!
        else Reject
            A->>S: UPDATE status=rejected
        end
    end

    rect rgb(237, 233, 254)
        Note over U,N: CHECK STATUS
        U->>F: Open MyPage
        F->>S: Query submissions & receipts
        S-->>U: Show Status & Stamps
    end
