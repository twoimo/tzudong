%%{init: {'theme': 'default'}}%%

flowchart TB
    subgraph INPUT["Receipt Upload"]
        I1[User uploads receipt image]
        I2[Store in Supabase Storage]
    end

    subgraph OCR["Gemini Vision OCR"]
        O1[Call Gemini Vision API]
        O2[Extract Store Name]
        O3[Extract Visit Date]
        O4[Extract Total Amount]
        O5[Parse Address if visible]
    end

    subgraph MATCH["Restaurant Matching"]
        M1[Search by OCR Store Name]
        M2[Fuzzy Match Algorithm]
        M3[Address Similarity Check]
        M4{Match Found?}
    end

    subgraph DUP["Duplicate Detection"]
        D1[Query existing receipts]
        D2[Check same user + restaurant]
        D3[Check date within 24 hours]
        D4[Check amount similarity]
        D5{Is Duplicate?}
    end

    subgraph RESULT["Result"]
        R1[Mark as Duplicate]
        R2[Auto-reject with reason]
        R3[Proceed to Admin Review]
        R4[Award Stamp on Approve]
    end

    INPUT --> OCR
    O1 --> O2 & O3 & O4 & O5
    OCR --> MATCH
    M1 --> M2 --> M3 --> M4
    M4 -->|Yes| DUP
    M4 -->|No| MANUAL[Manual Restaurant Selection]
    MANUAL --> DUP
    D1 --> D2 --> D3 --> D4 --> D5
    D5 -->|Yes| R1 --> R2
    D5 -->|No| R3 --> R4
