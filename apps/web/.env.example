# Admin insight chatbot + storyboard agent
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

NEXT_PUBLIC_NAVER_CLIENT_ID=your_naver_client_id
NEXT_PUBLIC_NAVER_CLIENT_SECRET=your_naver_client_secret

NEXT_PUBLIC_YOUTUBE_API_KEY_BYEON=your_youtube_api_key
GEMINI_OCR_YEON=your_gemini_api_key
STORYBOARD_AGENT_GEMINI_API_KEY=your_storyboard_gemini_api_key
STORYBOARD_AGENT_NANO_BANANA_MODEL=gemini-2.5-flash-preview
STORYBOARD_AGENT_NANO_BANANA_PRO_MODEL=gemini-2.5-pro-preview
STORYBOARD_AGENT_DEFAULT_PROFILE=nanobanana
GOOGLE_API_KEY=your_google_api_key

# Storyboard agent (optional)
# 기본 동작은 내부 생성(별도 서버 미필요). 별도 서버(backend/storyboard-agent)를 쓰려면 아래 값을 true로 설정
STORYBOARD_AGENT_REMOTE_ENABLED=false
STORYBOARD_AGENT_API_URL=http://localhost:8001
STORYBOARD_AGENT_CHAT_PATH=/chat
STORYBOARD_AGENT_TIMEOUT_MS=8000
STORYBOARD_AGENT_MAX_RETRIES=3
STORYBOARD_AGENT_RETRY_BASE_MS=300
STORYBOARD_AGENT_RETRY_MAX_MS=2000
STORYBOARD_ORCHESTRATOR_MAX_RETRIES=3

# Storyboard web search (예: 최신 트렌드 보강)
STORYBOARD_WEB_SEARCH_ENABLED=false
STORYBOARD_WEB_SEARCH_URL=https://api.tavily.com/search
STORYBOARD_WEB_SEARCH_TOKEN=
STORYBOARD_WEB_SEARCH_TIMEOUT_MS=8000

# 앱 본체 BGE 기반 스토리보드 검색(선택)
STORYBOARD_BGE_ENABLED=false
STORYBOARD_BGE_EMBEDDING_URL=
STORYBOARD_BGE_EMBEDDING_TOKEN=
STORYBOARD_BGE_EMBEDDING_TIMEOUT_MS=8000
STORYBOARD_BGE_MATCH_COUNT=8
STORYBOARD_BGE_MATCH_THRESHOLD=0.5
STORYBOARD_BGE_DENSE_WEIGHT=0.6
